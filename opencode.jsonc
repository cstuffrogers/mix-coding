{

  "instructions": ["CLAUDE.md"],

  "skills": {
    "paths": [".claude/skills"]
  },

  "command": {
    "polish": {
      "description": "美化前端项目 (DaisyUI / Animal Island UI / 自定义)",
      "prompt": "执行前端美化工作流。1) 确认目标路径 2) 弹出风格菜单供用户选择 3) 安装依赖并应用主题 4) 添加 Animate.css 动效 5) 测试验证 6) 生成报告。详细流程参考 CLAUDE.md /polish 章节。"
    },
    "review": {
      "description": "代码审查：静态分析 → React → 视觉 → AI 语义 → 聚合 + 安全审计",
      "prompt": "执行代码审查，支持 --mode pr|full|commit / --base / --layers 参数。Layer 1: 按技术栈运行对应 linter。Layer 2: React 反模式检查。Layer 3: Playwright 视觉回归。Layer 4: AI 语义审查。Layer 5: 聚合报告 + sec-bug-hunt 安全审计。详细流程参考 CLAUDE.md。"
    },
    "feature": {
      "description": "功能开发：理解需求 → 编写测试 → 实现 → CI 验证",
      "prompt": "启动功能开发场景。1) 理解需求并确认 2) 编写测试用例（TDD）3) 实现功能使测试通过 4) CI 验证。用法：/feature [功能描述]"
    },
    "bugfix": {
      "description": "Bug 修复：复现 → 定位根因 → 修复 → 验证",
      "prompt": "启动 Bug 修复场景。1) 复现问题 2) 定位根因 3) 制定修复方案 4) 修复并验证测试通过。使用 systematic-debugging skill 分析问题。用法：/bugfix [问题描述]"
    },
    "hunt": {
      "description": "安全漏洞扫描：规则扫描 + 依赖检查 + 自动修复",
      "prompt": "启动安全漏洞审查。1) 安全规则扫描（XSS/SQL注入/CSRF/硬编码密钥）2) 依赖漏洞扫描（npm audit）3) 自动修复 4) 生成报告。使用 sec-bug-hunt skill。"
    },
    "analyze": {
      "description": "竞品分析：OpenDigger 活跃度/影响力/质量数据",
      "prompt": "启动竞品分析。1) 调用 OpenDigger 获取项目数据 2) 分析活跃度、影响力、质量指标 3) 生成对比分析报告。用法：/analyze [项目名]"
    },
    "design": {
      "description": "AI 驱动设计：多风格方案 → 确认 → 输出规范",
      "prompt": "启动 AI 驱动设计。1) 调用 Open Design 理解需求 2) 生成多风格方案 3) 用户确认 4) 输出设计规范。用法：/design [设计描述]"
    },
    "simplify": {
      "description": "分析并简化代码逻辑，保持行为不变",
      "prompt": "分析代码，识别可简化点：减少嵌套、消除重复、合并条件、提取函数。保持行为不变。"
    },
    "optimize": {
      "description": "性能测量与优化",
      "prompt": "分析性能瓶颈，测量当前性能，实施优化，验证改进效果。"
    },
    "refactor": {
      "description": "重构指定模块",
      "prompt": "重构指定模块：分析代码结构，制定计划，执行重构，验证测试通过。用法：/refactor [目标模块]"
    },
    "new-project": {
      "description": "创建新项目：理解需求 → 创建结构 → 初始化配置",
      "prompt": "创建新项目：理解需求，创建目录结构，初始化配置，安装依赖。用法：/new-project [项目描述]"
    },
    "plan": {
      "description": "创建实施计划：重述需求 → 评估风险 → 分步规划 → 等待确认",
      "prompt": "创建全面的实施计划。1) 重述需求以确认理解 2) 识别风险和阻塞项 3) 将实现分解为阶段 4) 标记依赖关系和复杂性 5) 呈现计划后等待用户确认才能写代码。支持 PRD 文件输入。详细流程参考 .claude/commands/plan.md。"
    },
    "build-fix": {
      "description": "检测构建系统并增量修复构建/类型错误",
      "prompt": "增量修复构建和类型错误。1) 检测项目构建工具 2) 运行构建命令捕获错误 3) 按文件分组并按依赖排序 4) 逐一修复（每次读文件→诊断→最小化编辑→重新验证）5) 报告修复结果。每次只修复一个错误，优先最小 diff。"
    },
    "loop": {
      "description": "启动迭代优化循环：分析 → 计划 → 实现 → 验证 → 重复",
      "prompt": "启动迭代优化循环。Phase 1: 分析当前状态并评分。Phase 2: 制定本迭代计划。Phase 3: 实现更改。Phase 4: 运行测试和 linter 验证。Phase 5: 评分对比，不改进则停止。最大 10 次迭代。用法：/loop [迭代次数] \"[任务描述]\""
    },
    "checkpoint": {
      "description": "创建/验证/列出工作流检查点",
      "prompt": "管理检查点。create: 运行 lint+test 确保干净状态，git commit/stash 并记录到 .claude/checkpoints.log。verify: 对比当前状态（文件变更/测试通过率/覆盖率差异）。list: 显示所有检查点。用法：/checkpoint create|verify|list [name]"
    },
    "save-session": {
      "description": "保存当前会话状态到 ~/.claude/session-data/ 供后续恢复",
      "prompt": "捕获会话完整状态并写入日期文件。1) 收集上下文（git diff 变更、已讨论内容、错误及解决）2) 按模板写入 ~/.claude/session-data/ 3) 展示文件内容 4) 等待用户确认准确性。包含：构建内容、工作/失败的尝试、文件状态、决策、阻塞项、确切的下一步。"
    },
    "resume-session": {
      "description": "加载最近会话文件并恢复完整上下文",
      "prompt": "加载之前保存的会话状态。1) 查找 ~/.claude/session-data/ 中最新的 -session.tmp 文件（或按日期/路径加载）2) 完整读取 3) 以结构化简报格式呈现（项目、当前状态、不要重试的内容、阻塞项、下一步）4) 等待用户指示才开始工作。不可自动修改任何文件。"
    },
    "learn": {
      "description": "从当前会话提取可复用模式并保存为候选 skill",
      "prompt": "分析当前会话提取有价值模式。1) 回顾会话 2) 识别最可复用的洞察（错误解决模式/调试技巧/库变通方案/项目模式）3) 按模板草拟 skill 文件 4) 用户确认后保存到 ~/.claude/skills/learned/。不提取琐碎修复或一次性问题。"
    },
    "evolve": {
      "description": "分析已学模式，评估成熟度，将高质量模式提升为正式 skill",
      "prompt": "评估 /learn 保存的模式。1) 扫描 ~/.claude/skills/learned/ 等目录 2) 按通用性/清晰度/价值/稳定性评分（0-10）3) ≥7.0 提升为正式 skill，5.0-7.0 建议改进，<5.0 存档 4) 记录到进化日志。用法：/evolve"
    },
    "test-coverage": {
      "description": "分析覆盖率，识别缺口，生成缺失测试至 80%+",
      "prompt": "提升测试覆盖率至 80%+。1) 检测测试框架并运行覆盖率 2) 解析报告，列出低于 80% 的文件 3) 对每个欠覆盖文件生成缺失测试（先 happy path → 错误处理 → 边界情况 → 分支覆盖）4) 运行全量测试确保通过 5) 重新运行覆盖率验证改进。"
    },
    "update-docs": {
      "description": "从源码真相文件同步文档：脚本、环境变量、路由等",
      "prompt": "同步代码与文档。1) 从 package.json 读取脚本生成参考表 2) 从 .env.example 提取环境变量文档 3) 更新 CONTRIBUTING.md 和 RUNBOOK.md 4) 检查 90+ 天未修改的文档 5) 报告更新/标记/跳过项。使用 <!-- AUTO-GENERATED --> 标记。"
    },
    "update-codemaps": {
      "description": "扫描项目结构并生成 token-lean 架构 codemap",
      "prompt": "生成架构 codemap。1) 扫描项目结构（入口点/源目录/类型）2) 在 docs/CODEMAPS/ 中创建/更新 architecture.md、backend.md、frontend.md、data.md、dependencies.md 3) token-lean 格式（路径和签名优先，token < 1000）4) 差异检测：变化 >30% 需用户批准。"
    },
    "quality-gate": {
      "description": "对文件或项目作用域运行质量检查并报告修复步骤",
      "prompt": "运行质量门禁。1) 检测目标语言/工具 2) 运行格式化检查 3) 运行 lint/类型检查 4) 生成简洁的修复列表。支持 --fix（自动修复）和 --strict（警告即失败）。用法：/quality-gate [path] [--fix] [--strict]"
    },
    "project-init": {
      "description": "检测项目技术栈并生成 ECC 入职方案（默认 dry-run）",
      "prompt": "创建安全的 ECC 入职方案。1) 默认 dry-run 模式，不写文件 2) 检测技术栈（package.json、pyproject.toml、go.mod 等）3) 生成最小方案 4) 报告将要更改的内容 5) 等待用户批准后才真正写入。支持 --target claude|cursor|opencode。"
    },
    "auto-update": {
      "description": "从上游仓库拉取最新更改并重新应用项目配置",
      "prompt": "从项目上游仓库拉取最新更改，自动迁移 ECC 配置。1) git pull 2) 检测配置变更 3) 重新应用项目本地配置 4) 报告更新内容。"
    },
    "sessions": {
      "description": "管理会话历史：列出、加载和查看会话元数据",
      "prompt": "管理会话记录。1) 列出 ~/.claude/session-data/ 中所有会话 2) 加载指定会话查看详情 3) 支持别名和元数据筛选。用法：/sessions [list|load <name>]"
    },
    "marketing-campaign": {
      "description": "规划并执行完整营销活动：简介→文案→邮件→社交→广告→日历",
      "prompt": "从产品简介生成完整营销方案。1) 理解产品/目标受众 2) 生成着陆页文案 3) 创建邮件序列 4) 社交媒体帖子 5) 广告变体 6) 视频脚本 7) 内容日历。用法：/marketing-campaign [产品简介]"
    },
    "jira": {
      "description": "检索 Jira 工单、分析需求、更新状态或添加评论",
      "prompt": "与 Jira 集成。1) 检索工单详情 2) 分析需求 3) 更新工单状态 4) 添加评论。使用 jira-integration skill 和 MCP 或 REST API。用法：/jira [工单号] [操作]"
    },
    "review-pr": {
      "description": "使用多视角子代理进行全面的 PR 审查",
      "prompt": "对当前 PR 分支进行全面审查。1) 多子代理并行分析（架构/安全/性能/可读性）2) 收集各视角反馈 3) 聚合生成最终审查报告 4) 列出关键问题和建议。"
    },
    "prune": {
      "description": "清除过时或低价值的已学习模式，维护知识库健康",
      "prompt": "清理低价值已学习模式。1) 扫描 ~/.claude/skills/learned/ 等地 2) 按使用频率和上次访问时间评估 3) 标记过时/低价值条目 4) 用户确认后删除。"
    },
    "promote": {
      "description": "手动将已学习模式提升为正式 skill",
      "prompt": "手动升级已学习模式为正式 skill。1) 选择要提升的模式 2) 转换格式为正式 SKILL.md 3) 写入 .claude/skills/ 或 ~/.claude/skills/ 4) 记录升级日志。"
    },
    "projects": {
      "description": "列出并管理 ECC 生态中已知项目及其模式",
      "prompt": "管理 ECC 项目列表。1) 显示所有已知项目 2) 每个项目的已学习模式和 skill 统计 3) 支持按名称筛选。用法：/projects [项目名]"
    },
    "security-scan": {
      "description": "运行实用安全扫描：npm audit + ESLint 安全模式 + 文件检查",
      "prompt": "执行安全扫描。1) npm audit 依赖漏洞检查 2) ESLint 安全规则扫描（危险模式、硬编码密钥）3) 文件模式匹配检查（密钥泄露等）4) 聚合报告与修复建议。"
    },
    "loop-start": {
      "description": "启动受管理的自主循环模式，内置安全默认值和显式停止条件",
      "prompt": "启动可控的自主循环。1) 设定目标和迭代次数上限 2) 安全防护（git stash 前保护、每次迭代验证）3) 监控进度 4) 满足停止条件时自动退出。用法：/loop-start [目标] [迭代次数]"
    },
    "loop-status": {
      "description": "检查活跃循环、长期运行进程和卡死状态",
      "prompt": "诊断循环状态。1) 检查活跃循环进程 2) 检查 git 卡死状态 3) 报告资源使用情况 4) 建议下一步操作。"
    },
    "refactor-clean": {
      "description": "安全识别并移除死代码，每次更改后验证",
      "prompt": "安全移除死代码。1) 分析代码识别未使用的函数/变量/导入 2) 逐个移除 3) 每次删除后运行测试验证 4) 报告清理摘要。"
    },
    "model-route": {
      "description": "根据复杂度、风险和预算推荐最佳模型层级",
      "prompt": "分析任务并推荐模型。1) 评估任务复杂度 2) 评估风险等级 3) 考虑预算约束 4) 推荐最佳模型层级（haiku/sonnet/opus）并说明理由。"
    },
    "cost-report": {
      "description": "生成本地 API 使用成本报告",
      "prompt": "从本地数据库生成成本报告。1) 查询 API 使用记录 2) 按时间/模型/项目分组 3) 计算总成本和平均成本 4) 显示报告。"
    },
    "setup-pm": {
      "description": "配置偏好的包管理器（npm/pnpm/yarn/bun）",
      "prompt": "设置包管理器。1) 检测当前项目锁定文件 2) 建议或确认包管理器 3) 生成 .npmrc / .pnpmrc 等配置 4) 可选设置为全局默认。用法：/setup-pm [npm|pnpm|yarn|bun]"
    },
    "feature-dev": {
      "description": "引导式功能开发：代码库理解→架构→实现→验证",
      "prompt": "引导功能开发全流程。1) 理解需求 2) 探索代码库相关部分 3) 架构设计 4) 分步实现 5) 测试验证。比 /feature 更注重架构分析和代码库理解。用法：/feature-dev [功能描述]"
    },
    "learn-eval": {
      "description": "从会话提取模式并在保存前自我评估质量",
      "prompt": "提取会话模式并评估质量。1) 回顾会话 2) 识别可复用模式 3) 按通用性/清晰度/价值/稳定性自评 4) 决定保存位置（全局/项目）5) 用户确认后保存。比 /learn 多一步质量把控。"
    },
    "skill-health": {
      "description": "显示 skill 生态系统健康仪表盘",
      "prompt": "检查 skill 生态健康。1) 扫描所有 skill 目录 2) 检查每项的前置元数据完整性 3) 报告使用频率和最后更新 4) 标记问题 skill。用法：/skill-health"
    },
    "skill-create": {
      "description": "从 git 历史分析提取编码模式并生成 SKILL.md",
      "prompt": "从 git 历史提取模式。1) 分析 git log 2) 识别重复出现的问题/修复模式 3) 总结为可复用指导 4) 生成 SKILL.md 文件 5) 用户确认后保存到 skills/。"
    },
    "instinct-status": {
      "description": "显示已学习模式的当前状态：数量、成熟度、覆盖率",
      "prompt": "显示已学模式仪表盘。1) 统计已学习模式总数 2) 按成熟度分类 3) 计算项目覆盖度 4) 展示趋势图。用法：/instinct-status"
    },
    "instinct-import": {
      "description": "从导出文件或外部源导入已学习模式",
      "prompt": "导入已学习模式。1) 读取导出文件 2) 验证格式 3) 合并到本地知识库 4) 报告导入结果。用法：/instinct-import [文件路径]"
    },
    "instinct-export": {
      "description": "将已学习模式导出为可移植文件用于共享或备份",
      "prompt": "导出已学习模式。1) 选择要导出的模式 2) 序列化为可移植格式 3) 写入导出文件 4) 报告导出位置。用法：/instinct-export [输出路径]"
    },
    "ecc-guide": {
      "description": "ECC 生态系统交互式导航地图：代理/技能/命令/钩子",
      "prompt": "导航 ECC 生态系统。1) 展示 ECC 当前可用代理列表 2) 展示可用技能 3) 展示可用命令 4) 展示钩子配置 5) 展示安装配置文件 6) 引导用户到适合的工具。"
    },
    "harness-audit": {
      "description": "运行确定性仓库审计并返回优先评分卡",
      "prompt": "审计仓库的 AI 编码准备状态。1) 按 12 个类别评分（CLAUDE.md、测试、lint、CI、文档等）2) 为每个类别打分 3) 生成优先改进列表 4) 返回评分卡报告。"
    },
    "pm2": {
      "description": "分析项目并为检测到的服务生成 PM2 配置",
      "prompt": "生成 PM2 配置。1) 分析项目服务（前端/后端/数据库）2) 检测入口点和运行命令 3) 生成 ecosystem.config.js 4) 提供管理命令。用法：/pm2"
    },
    "hookify": {
      "description": "创建钩子规则以防止不需要的行为",
      "prompt": "创建预防性钩子规则。1) 分析不需要的行为模式 2) 编写检查条件 3) 定义触发动作 4) 保存到 hooks/ 目录。用法：/hookify [行为描述]"
    },
    "hookify-list": {
      "description": "列出所有已配置的 hookify 规则",
      "prompt": "显示所有活跃的钩子规则。1) 扫描 hooks/ 目录 2) 解析每条规则的触发条件和动作 3) 以表格格式展示。用法：/hookify-list"
    },
    "hookify-help": {
      "description": "获取 hookify 系统的文档和用法",
      "prompt": "显示钩子系统文档。1) 钩子规则格式说明 2) 可用命令列表 3) 配置示例。用法：/hookify-help"
    },
    "hookify-configure": {
      "description": "交互式启用或禁用 hookify 规则",
      "prompt": "管理钩子规则开关。1) 列出所有规则及当前状态 2) 选择要切换的规则 3) 启用/禁用。用法：/hookify-configure"
    },
    "prp-implement": {
      "description": "使用严格验证循环执行实施计划",
      "prompt": "执行计划文件。1) 读取 .claude/PRPs/plans/ 中指定的计划 2) 按步骤执行 3) 每步后验证 4) 报告进度。用法：/prp-implement [计划路径]"
    },
    "prp-commit": {
      "description": "快速提交：自然语言描述文件变更",
      "prompt": "自然语言提交。1) 分析用户自然语言描述的变更 2) 匹配到具体文件 3) git add 相关文件 4) git commit。用法：/prp-commit [描述哪些文件做了什么]"
    },
    "prp-pr": {
      "description": "从当前分支创建 GitHub PR，含模板匹配和变更分析",
      "prompt": "创建 PR。1) 检测 PR 模板 2) 分析分支变更 3) 生成描述 4) 推送分支 5) 使用 gh CLI 创建 PR。用法：/prp-pr"
    },
    "prp-prd": {
      "description": "交互式 PRD 生成器：问题优先、假设驱动的产品规格",
      "prompt": "生成 PRD。1) 先提问理解问题和假设 2) 来回对话细化需求 3) 输出结构化 PRD 文档 4) 保存到 .claude/PRPs/prds/。用法：/prp-prd [产品/功能名称]"
    },
    "prp-plan": {
      "description": "创建全面实施计划，含代码库分析和模式提取",
      "prompt": "生成实施计划。1) 分析需求 2) 探索代码库相关部分 3) 提取现有模式 4) 分步计划 5) 保存到 .claude/PRPs/plans/。用法：/prp-plan [功能描述]"
    },
    "multi-execute": {
      "description": "执行多代理实施计划，仅 Claude 作为文件系统写入者",
      "prompt": "多代理执行计划。1) 读取计划 2) 调度前端/后端子代理 3) Claude 独占文件写入 4) 合并成果 5) 验证。用法：/multi-execute [计划路径]"
    },
    "multi-backend": {
      "description": "运行后端聚焦的多代理工作流：API/算法/数据/业务逻辑",
      "prompt": "后端聚焦多代理工作流。1) 选择后端代理 2) 分析需求 3) 并行执行 4) 代码审查 5) 合并。用法：/multi-backend [后端需求描述]"
    },
    "multi-frontend": {
      "description": "运行前端聚焦的多代理工作流：组件/布局/动画/UI",
      "prompt": "前端聚焦多代理工作流。1) 选择前端代理 2) 分析需求 3) 并行执行 4) 代码审查 5) 合并。用法：/multi-frontend [前端需求描述]"
    },
    "multi-plan": {
      "description": "使用并行前端/后端专家代理创建多代理计划",
      "prompt": "多代理规划。1) 分析需求 2) 分配给前端和后端子代理并行分析 3) 合并计划 4) 输出多阶段执行计划。用法：/multi-plan [需求描述]"
    },
    "multi-workflow": {
      "description": "完整 6 阶段多代理开发：研究→规划→执行→优化→审查",
      "prompt": "完整多代理开发工作流。1) 研究阶段 2) 规划阶段 3) 执行阶段 4) 优化阶段 5) 审查阶段 6) 质量门禁。用法：/multi-workflow [项目描述]"
    },
    "gan-design": {
      "description": "生成器/评估器设计迭代循环：视觉/前端设计",
      "prompt": "设计迭代循环。1) 生成器创建设计方案 2) 评估器评分 3) 循环改进 4) 达到迭代上限或评分满意后输出。用法：/gan-design [设计目标]"
    },
    "gan-build": {
      "description": "生成器/评估器构建迭代循环：实施任务 + Playwright 验证",
      "prompt": "构建迭代循环。1) 生成器构建实现 2) 评估器审查 3) Playwright 验证 4) 循环改进 5) 达到上限后输出。用法：/gan-build [构建目标]"
    },
    "santa-loop": {
      "description": "对抗性双审查收敛循环：两个独立代理都批准后才发布",
      "prompt": "双审查对抗循环。1) 两个独立子代理分别审查 2) 都批准才能继续 3) 有分歧时迭代直到收敛 4) 报告最终结果。"
    },
    "cpp-review": {
      "description": "C++ 代码审查：内存安全/现代 C++/并发/安全",
      "prompt": "审查 C++ 代码。1) 检查内存安全（裸指针、new/delete）2) 现代 C++ 惯用语法 3) 并发安全 4) 安全漏洞。运行 clang-tidy。"
    },
    "cpp-test": {
      "description": "C++ TDD：先编写 GoogleTest 测试，再实现，gcov 验证覆盖率",
      "prompt": "C++ TDD 工作流。1) 编写 GoogleTest 测试（RED）2) 实现使测试通过（GREEN）3) gcov/lcov 验证覆盖率 4) 重构。用法：/cpp-test [测试描述]"
    },
    "cpp-build": {
      "description": "增量修复 C++ 构建/CMake/链接器错误",
      "prompt": "修复 C++ 构建错误。1) 运行 cmake/make 捕获错误 2) 按编译/链接分组 3) 逐一修复 4) 每次后重新构建验证。"
    },
    "flutter-review": {
      "description": "Flutter/Dart 审查：小部件模式/状态管理/性能/可访问性",
      "prompt": "审查 Flutter/Dart 代码。1) 小部件最佳实践 2) 状态管理 3) 性能 4) 可访问性 5) 安全性。"
    },
    "flutter-test": {
      "description": "运行 Flutter 测试：单元/小部件/金快照/集成，修复失败",
      "prompt": "运行并修复 Flutter 测试。1) 运行 flutter test 2) 分析失败原因 3) 增量修复 4) 重新验证。涵盖单元、小部件、金快照、集成测试。"
    },
    "flutter-build": {
      "description": "修复 Dart 分析器错误和 Flutter 构建失败",
      "prompt": "修复 Flutter 构建。1) 运行 dart analyze 2) 运行 flutter build 3) 按错误类型分组 4) 逐一修复 5) 重新验证。"
    },
    "go-review": {
      "description": "Go 代码审查：惯用模式/并发安全/错误处理",
      "prompt": "审查 Go 代码。1) 惯用 Go 模式 2) 并发安全（goroutine/race）3) 错误处理 4) 性能。运行 go vet + staticcheck。"
    },
    "go-test": {
      "description": "Go TDD：先编写表格驱动测试，再实现，go test -cover 验证",
      "prompt": "Go TDD 工作流。1) 编写表格驱动测试（RED）2) 实现使测试通过（GREEN）3) go test -cover 验证 80%+ 4) 重构。用法：/go-test [测试描述]"
    },
    "go-build": {
      "description": "增量修复 Go 构建/go vet/linter 错误",
      "prompt": "修复 Go 构建错误。1) 运行 go build 和 go vet 2) 按模块分组 3) 逐一修复 4) 每次后验证。"
    },
    "kotlin-review": {
      "description": "Kotlin 审查：空安全/协程/惯用语法",
      "prompt": "审查 Kotlin 代码。1) 空安全 2) 协程正确性 3) 惯用 Kotlin 4) Android/Compose 最佳实践。"
    },
    "kotlin-test": {
      "description": "Kotlin TDD：先编写 Kotest 测试，再实现，Kover 验证覆盖率",
      "prompt": "Kotlin TDD 工作流。1) 编写 Kotest 测试（RED）2) 实现使测试通过（GREEN）3) Kover 验证 80%+ 4) 重构。用法：/kotlin-test [测试描述]"
    },
    "kotlin-build": {
      "description": "增量修复 Kotlin/Gradle 构建和编译错误",
      "prompt": "修复 Kotlin 构建错误。1) 运行 ./gradlew build 2) 按编译器/错误分组 3) 逐一修复 4) 每次后验证。"
    },
    "python-review": {
      "description": "Python 审查：PEP 8/类型提示/安全/惯用语法",
      "prompt": "审查 Python 代码。1) PEP 8 合规 2) 类型提示正确性 3) 安全性 4) Python 惯用语法。运行 ruff + mypy。"
    },
    "rust-review": {
      "description": "Rust 审查：所有权/生命周期/不安全使用/惯用模式",
      "prompt": "审查 Rust 代码。1) 所有权和生命周期问题 2) 不安全代码块 3) 错误处理 4) 惯用 Rust。运行 cargo clippy。"
    },
    "rust-test": {
      "description": "Rust TDD：先编写测试，再实现，cargo-llvm-cov 验证覆盖率",
      "prompt": "Rust TDD 工作流。1) 编写测试（RED）2) 实现使测试通过（GREEN）3) cargo-llvm-cov 验证 80%+ 4) 重构。用法：/rust-test [测试描述]"
    },
    "rust-build": {
      "description": "增量修复 Rust 构建/借用检查器/依赖错误",
      "prompt": "修复 Rust 构建错误。1) 运行 cargo build 捕获错误 2) 按借用检查/类型/依赖分组 3) 逐一修复 4) 每次后验证。"
    },
    "fastapi-review": {
      "description": "FastAPI 审查：架构/异步/依赖注入/Pydantic/安全",
      "prompt": "审查 FastAPI 应用。1) 路由器和模式设计 2) 异步正确性 3) 依赖注入 4) Pydantic 模型 5) 安全性 6) 可测试性。"
    },
    "gradle-build": {
      "description": "修复 Android 和 KMP 项目的 Gradle 构建错误",
      "prompt": "修复 Gradle 构建错误。1) 运行 ./gradlew build 2) 分析错误（依赖/DSL/插件）3) 逐一修复 4) 验证。"
    }
  },

  "mcp": {
    "codegraph": {
      "type": "local",
      "command": ["codegraph", "serve", "--mcp"],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "env": { "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}" },
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp", "--browser", "chromium"],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "tavily-search": {
      "type": "local",
      "command": ["npx", "-y", "@tavily/mcp"],
      "env": { "TAVILY_API_KEY": "${TAVILY_API_KEY}" },
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "env": { "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}" },
      "enabled": true
    }
  }
}
