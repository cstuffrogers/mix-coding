# ── API 配置 ──
API_BASE_URL=https://api.example.com
API_TIMEOUT=30000

# ── 推送通知 ──
# iOS APNs Key ID
APNS_KEY_ID=
# Android FCM Server Key
FCM_SERVER_KEY=

# ── 第三方服务 ──
# 地图 (Google Maps / AMap)
MAPS_API_KEY=
# 支付 (Stripe / Alipay / WeChat Pay)
PAYMENT_API_KEY=
# 分析 (Firebase / Sentry)
SENTRY_DSN=

# ── 安全扫描（可选，未配置时对应步骤自动跳过）──
SOCKET_API_KEY=
SERAPHIM_AUDIT_URL=
SUPERMEMORY_API_KEY=
