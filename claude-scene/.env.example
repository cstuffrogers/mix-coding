# ── LLM API ──
# Claude Code 会自动从系统配置中获取 API Key，此处可选覆盖
# ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-...

# ── 项目根目录（可选，默认自动检测）──
# AUTO_CODING_ROOT=/path/to/auto-coding

# ── 运行时 ──
# NODE_ENV=production
# LOG_LEVEL=info

# ── 通知（可选，未配置时自动跳过）──
# SENTRY_DSN=

# ── 安全扫描（可选）──
# SERAPHIM_AUDIT_URL=https://your-site.com    # 启用实时 URL 安全响应头扫描


# ── 移动端开发（可选）──
# ANDROID_HOME=/path/to/Android/Sdk
