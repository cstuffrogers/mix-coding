{
  "scene_id": "new-project",
  "workflow": "new-project",
  "name": "从零开始新项目",
  "description": "从零开始新项目：Pre-flight 设计基准 → shape 设计简报确立品味方向 → 上下文收集 → Skill 规划 → 脚手架 → Open Design → Impeccable 全维度打磨（critique 检测→12 fixes→critique 验证→3 精准修复→Huashu 验证，双轮品控+残留修复）+ AI-Friendly 可访问性审查 → 实现 → 审查 → CE 沉淀（65步）",
  "trigger_keywords": [
    "从零开始",
    "新项目",
    "做一个",
    "搭建",
    "创建"
  ],
  "flow": [
    {
      "step": 0.3,
      "layer": "skill",
      "service": "Skill",
      "action": "invokeSkill",
      "params": {
        "skill": "web-design-engineer"
      },
      "description": "Pre-flight: 声明设计系统基准（Palette/Typography/Spacing/Motion/Radius/Shadows），加载 150 品牌系统",
      "condition": "conversation_mode && frontend_involved"
    },
    {
      "step": 0.5,
      "layer": "skill",
      "service": "Skill",
      "action": "invokeSkill",
      "params": {
        "skill": "review-checklist"
      },
      "description": "Pre-flight: 加载 23 项审查清单，建立项目初始化分析框架",
      "condition": "conversation_mode"
    },
    {
      "step": 0.7,
      "layer": "capability",
      "service": "MemoryService",
      "action": "recall",
      "params": {
        "mode": "full"
      },
      "description": "全量记忆注入（Claude-Mem + agentmemory + NEXO + CodeGraph）"
    },
    {
      "step": 0.71,
      "layer": "skill",
      "service": "Skill",
      "action": "invokeSkill",
      "params": {
        "skill": "impeccable",
        "subcommand": "shape"
      },
      "description": "Impeccable shape: 设计发现访谈 → 10 节设计简报（mood/references/color strategy/design direction/bold move），在新项目启动前建立品味方向约束",
      "condition": "impeccable_available && conversation_mode && frontend_involved",
      "on_error": "abort"
    },
    {
      "step": 1,
      "layer": "capability",
      "service": "GitHubMCP",
      "action": "searchRepositories",
      "params": {
        "query": "best practices project architecture 2024",
        "limit": 5
      },
      "description": "使用 GitHub MCP 搜索最佳实践仓库",
      "condition": "github_mcp_available"
    },
    {
      "step": 1.1,
      "layer": "capability",
      "service": "TavilyMCP",
      "action": "search",
      "params": {
        "query": "project best practices architecture 2024",
        "limit": 10
      },
      "description": "使用 Tavily MCP 搜索项目类型最佳实践",
      "condition": "tavily_mcp_available"
    },
    {
      "step": 1.2,
      "layer": "capability",
      "service": "Context7MCP",
      "action": "getDocumentation",
      "params": {
        "topic": "current project tech stack"
      },
      "description": "使用 Context7 MCP 获取相关技术栈文档",
      "condition": "context7_mcp_available"
    },
    {
      "step": 1.3,
      "layer": "capability",
      "service": "SupabaseMCP",
      "action": "getSchema",
      "params": {
        "project": "template"
      },
      "description": "使用 Supabase MCP 获取数据库模板",
      "condition": "supabase_mcp_available && database_required"
    },
    {
      "step": 1.4,
      "layer": "capability",
      "service": "StripeMCP",
      "action": "getPaymentFlow",
      "params": {
        "type": "template"
      },
      "description": "使用 Stripe MCP 获取支付流程模板",
      "condition": "stripe_mcp_available && payment_required"
    },
    {
      "step": 1.5,
      "layer": "capability",
      "service": "ResendMCP",
      "action": "getEmailTemplate",
      "params": {
        "type": "onboarding"
      },
      "description": "使用 Resend MCP 获取邮件模板",
      "condition": "resend_mcp_available && email_required"
    },
    {
      "step": 1.6,
      "layer": "interactive",
      "service": "OpenDiggerService",
      "action": "analyze",
      "params": {
        "metric": "openrank",
        "period": "90d"
      },
      "description": "竞品分析（条件触发；repo 由场景引擎从用户输入中提取）",
      "auto_execute": false,
      "condition": "user_mentioned_competitor_or_domain"
    },
    {
      "step": 2,
      "layer": "capability",
      "service": "ECC",
      "action": "ce-plan",
      "params": {
        "detail_level": "high",
        "risk_analysis": true,
        "tech_selection": true
      },
      "description": "CE Plugin 生成详细项目规划：技术选型、架构设计、任务拆解、时间预估",
      "condition": "plugin_ce_available"
    },
    {
      "step": 2.5,
      "layer": "skill",
      "service": "Skill",
      "action": "invokeSkill",
      "params": {
        "skill": "review"
      },
      "description": "Skill: Matt Pocock /to-prd 替代 — 从对话上下文合成 PRD 并发布到项目 Issue Tracker",
      "condition": "conversation_mode"
    },
    {
      "step": 2.6,
      "layer": "skill",
      "service": "Skill",
      "action": "invokeSkill",
      "params": {
        "skill": "review"
      },
      "description": "Skill: Matt Pocock /to-issues 替代 — 将 PRD 拆解为可独立抓取的垂直切片 Issue",
      "condition": "conversation_mode"
    },
    {
      "step": 3,
      "layer": "capability",
      "service": "ProjectService",
      "action": "applyTemplate",
      "params": {},
      "description": "项目脚手架：创建目录结构、初始化 package.json/tsconfig/vite.config 等配置文件",
      "on_error": "abort"
    },
    {
      "step": 3.1,
      "layer": "skill",
      "service": "Skill",
      "action": "invokeSkill",
      "params": {
        "skill": "review"
      },
      "description": "Git guardrails: 配置 PreToolUse Hook 拦截危险 git 命令（force push/reset --hard/checkout .），保护开发全过程",
      "condition": "conversation_mode"
    },
    {
      "step": 3.5,
      "layer": "interactive",
      "service": "PromptService",
      "action": "askUser",
      "params": {
        "prompt": "是否需要使用 Open Design 开发 UI 界面？",
