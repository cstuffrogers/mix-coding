{
  "scene_id": "monitor",
  "workflow": "monitor",
  "name": "监控配置",
  "description": "使用 Upptime 配置 GitHub Actions 原生网站监控，自动生成配置文件和工作流，并部署状态页面",
  "trigger_keywords": [
    "监控",
    "monitor",
    "uptime",
    "状态页",
    "健康检查配置",
    "可用性监控"
  ],
  "flow": [
    {
      "step": 1,
      "layer": "core",
      "service": "MemoryService",
      "action": "recall",
      "params": {
        "type": "monitor",
        "filters": {
          "type": [
            "monitor",
            "uptime",
            "performance",
            "health"
          ]
        }
      },
      "description": "注入监控相关记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 2,
      "layer": "capability",
      "service": "MonitorService",
      "action": "setupMonitor",
      "params": {},
      "description": "检测项目类型，生成 .upptimerc.yml 和 GitHub Actions 工作流",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3,
      "layer": "core",
      "service": "QualityService",
      "action": "checkGate",
      "params": {
        "checks": [
          "monitor"
        ]
      },
      "description": "监控配置质量门禁",
      "auto_execute": true,
      "condition": "monitorConfigured == false",
      "on_error": "abort"
    },
    {
      "step": 4,
      "layer": "capability",
      "service": "MonitorService",
      "action": "autoFix",
      "params": {
        "source": "monitor"
      },
      "description": "自动修复监控配置问题",
      "auto_execute": true,
      "condition": "monitorConfigured == false",
      "on_error": "continue"
    },
    {
      "step": 5,
      "layer": "core",
      "service": "NotificationService",
      "action": "send",
      "params": {
        "level": "warning",
        "title": "监控配置失败",
        "content": "Upptime 配置未能完成，请检查 Git 仓库设置和 GitHub 连接"
      },
      "description": "监控配置失败通知",
      "auto_execute": true,
      "condition": "monitorConfigured == false",
      "on_error": "continue"
    },
    {
      "step": 6,
      "layer": "capability",
      "service": "MemoryService",
      "action": "remember",
      "params": {
        "type": "monitor",
        "data": {
          "configPath": "{{monitorConfigPath}}",
          "workflowPath": "{{monitorWorkflowPath}}",
          "configured": "{{monitorConfigured}}"
        }
      },
      "description": "保存监控配置结果",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 7,
      "layer": "capability",
      "service": "MemoryService",
      "action": "consolidate",
      "params": {},
      "description": "整理去重记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 7.5,
      "layer": "capability",
      "service": "ECC",
      "action": "ce-compound",
      "params": {
        "type": "monitor",
        "source": "auto"
      },
      "description": "将monitor知识沉淀到项目知识库 CLAUDE.md",
      "auto_execute": true,
      "condition": "plugin_ce_available",
      "on_error": "continue"
    },
    {
      "step": 8,
      "layer": "core",
      "service": "NotificationService",
      "action": "notify",
      "params": {
        "message": "Upptime 监控配置工作流完成"
      },
      "description": "通知监控配置完成",
      "auto_execute": true,
      "on_error": "continue"
    }
  ],
  "status": "active"
}
