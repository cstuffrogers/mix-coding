{
  "scene_id": "incident",
  "workflow": "incident",
  "name": "Incident Runbook 生成",
  "description": "使用 Runme 生成可执行的 Markdown Incident Runbook，包含健康检查、常见问题、升级路径",
  "trigger_keywords": [
    "incident",
    "runbook",
    "事故",
    "故障",
    "应急",
    "oncall",
    "SRE",
    "运维手册"
  ],
  "flow": [
    {
      "step": 1,
      "layer": "core",
      "service": "MemoryService",
      "action": "recall",
      "params": {
        "type": "incident",
        "filters": {
          "type": [
            "incident",
            "runbook",
            "oncall",
            "sre"
          ]
        }
      },
      "description": "注入 Incident 相关记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 2,
      "layer": "capability",
      "service": "IncidentService",
      "action": "incidentRunbook",
      "params": {},
      "description": "扫描 API 端点、生成 Runme Markdown runbook",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3,
      "layer": "core",
      "service": "QualityService",
      "action": "checkGate",
      "params": {
        "checks": [
          "incident"
        ]
      },
      "description": "Runbook 质量门禁",
      "auto_execute": true,
      "condition": "incidentRunbookCreated == false",
      "on_error": "abort"
    },
    {
      "step": 4,
      "layer": "capability",
      "service": "IncidentService",
      "action": "autoFix",
      "params": {
        "source": "incident"
      },
      "description": "自动修复 Runbook 生成问题",
      "auto_execute": true,
      "condition": "incidentRunbookCreated == false",
      "on_error": "continue"
    },
    {
      "step": 5,
      "layer": "core",
      "service": "NotificationService",
      "action": "send",
      "params": {
        "level": "warning",
        "title": "Runbook 生成失败",
        "content": "未能生成 Incident Runbook，请检查项目结构和文件权限"
      },
      "description": "Runbook 生成失败通知",
      "auto_execute": true,
      "condition": "incidentRunbookCreated == false",
      "on_error": "continue"
    },
    {
      "step": 6,
      "layer": "capability",
      "service": "MemoryService",
      "action": "remember",
      "params": {
        "type": "incident",
        "data": {
          "incidentRunbookCreated": "{{incidentRunbookCreated}}",
          "runbookCount": "{{runbookCount}}",
          "runmeAvailable": "{{runmeAvailable}}"
        }
      },
      "description": "保存 Runbook 生成结果",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 7,
      "layer": "capability",
      "service": "MemoryService",
      "action": "consolidate",
      "params": {},
      "description": "整理去重记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 7.5,
      "layer": "capability",
      "service": "ECC",
      "action": "ce-compound",
      "params": {
        "type": "incident",
        "source": "auto"
      },
      "description": "将incident知识沉淀到项目知识库 CLAUDE.md",
      "auto_execute": true,
      "condition": "plugin_ce_available",
      "on_error": "continue"
    },
    {
      "step": 8,
      "layer": "core",
      "service": "NotificationService",
      "action": "notify",
      "params": {
        "message": "Incident Runbook 生成工作流完成"
      },
      "description": "通知 Runbook 生成完成",
      "auto_execute": true,
      "on_error": "continue"
    }
  ]
}
