{
  "scene_id": "simplify",
  "workflow": "simplify",
  "name": "代码简化",
  "description": "简化代码以提高可读性和可维护性，不改变行为（集成CE知识沉淀）",
  "trigger_keywords": [
    "简化",
    "简化代码",
    "code-simplify",
    "可读性",
    "清晰化"
  ],
  "flow": [
    {
      "step": 1,
      "layer": "capability",
      "service": "GitHubMCP",
      "action": "listIssues",
      "params": {
        "state": "open",
        "labels": [
          "simplify",
          "refactor"
        ],
        "limit": 5
      },
      "description": "使用 GitHub MCP 列出简化相关的 issues",
      "auto_execute": true,
      "condition": "github_mcp_available",
      "on_error": "continue"
    },
    {
      "step": 2,
      "layer": "capability",
      "service": "Context7MCP",
      "action": "getDocumentation",
      "params": {
        "topic": "code simplification best practices"
      },
      "description": "使用 Context7 MCP 获取代码简化最佳实践",
      "auto_execute": true,
      "condition": "context7_mcp_available",
      "on_error": "continue"
    },
    {
      "step": 3,
      "layer": "interactive",
      "service": "SceneSelector",
      "action": "confirm",
      "params": {
        "message": "确认简化范围：仅修改当前 feature 相关代码，不做 drive-by refactor"
      },
      "description": "确认简化范围，防止无范围简化",
      "auto_execute": false,
      "on_error": "abort"
    },
    {
      "step": 4,
      "layer": "capability",
      "service": "MemoryService",
      "action": "recall",
      "params": {
        "mode": "recent",
        "filters": {
          "type": "architecture"
        }
      },
      "description": "回忆架构决策和项目约定",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 5,
      "layer": "capability",
      "service": "TestEngine",
      "action": "runSuite",
      "params": {
        "mode": "unit"
      },
      "description": "运行测试建立基线（简化前必须全部通过）",
      "auto_execute": true,
      "on_error": "abort"
    },
    {
      "step": 6,
      "layer": "capability",
      "service": "ReviewEngine",
      "action": "runReview",
      "params": {
        "mode": "full"
      },
      "description": "审查识别简化机会：深层嵌套、长函数、嵌套三元式、布尔参数标志、重复逻辑、死代码",
      "auto_execute": true,
      "on_error": "retry"
    },
    {
      "step": 7,
      "layer": "interactive",
      "service": "SceneSelector",
      "action": "select",
      "params": {
        "options": [
          "简化深层嵌套（提取 guard clauses）",
          "拆分长函数（50+ lines）",
          "替换嵌套三元式为 if/else 或 lookup",
          "消除重复逻辑（提取共享函数）",
          "移除死代码（未使用变量、不可达分支）",
          "改善命名（generic → 具体描述）",
          "其他"
        ]
      },
      "description": "选择具体简化方向",
      "auto_execute": false,
      "on_error": "abort"
    },
    {
      "step": 8,
      "layer": "capability",
      "service": "TestEngine",
      "action": "runAffected",
      "params": {},
      "description": "每次简化后运行受影响测试",
      "auto_execute": true,
      "on_error": "abort"
    },
    {
      "step": 9,
      "layer": "capability",
      "service": "ReviewEngine",
      "action": "runReview",
      "params": {
        "mode": "pr"
      },
      "description": "简化后审查：确认无行为改变、遵循项目约定、diff 可 review",
      "auto_execute": true,
      "on_error": "retry"
    },
    {
      "step": 10,
      "layer": "capability",
      "service": "ECC",
      "action": "ce-compound",
      "params": {
        "type": "simplify",
        "source": "auto"
      },
      "description": "将代码简化知识沉淀到项目知识库 CLAUDE.md",
      "auto_execute": true,
      "condition": "plugin_ce_available",
      "on_error": "continue"
    },
    {
      "step": 11,
      "layer": "capability",
      "service": "MemoryService",
      "action": "remember",
      "params": {
        "type": "simplify",
        "data": {
          "source": "simplify_workflow"
        }
      },
      "description": "保存简化结果到记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 12,
      "layer": "capability",
      "service": "MemoryService",
      "action": "consolidate",
      "params": {},
      "description": "整理跨后端记忆一致性",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 13,
      "layer": "capability",
      "service": "NotificationService",
      "action": "notify",
      "params": {
        "type": "info",
        "message": "代码简化完成"
      },
      "description": "通知用户简化结果",
      "auto_execute": true,
      "on_error": "continue"
    }
  ],
  "status": "active"
}
