{
  "scene_id": "docker",
  "workflow": "docker",
  "name": "Docker 容器化配置",
  "description": "自动检测项目语言，生成多阶段 Dockerfile、.dockerignore、docker-compose.yml，验证 Docker 构建语法",
  "trigger_keywords": ["docker", "容器化", "container", "Dockerfile", "docker-compose"],
  "flow": [
    {
      "step": 1,
      "layer": "core",
      "service": "MemoryService",
      "action": "recall",
      "params": { "type": "docker", "filters": { "type": ["docker", "container", "deployment", "infrastructure"] } },
      "description": "注入 Docker 相关记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 2,
      "layer": "capability",
      "service": "DockerService",
      "action": "setupDocker",
      "params": {},
      "description": "检测语言，生成 Dockerfile + .dockerignore + docker-compose.yml",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3,
      "layer": "core",
      "service": "QualityService",
      "action": "checkGate",
      "params": { "checks": ["docker"] },
      "description": "Docker 配置质量门禁",
      "auto_execute": true,
      "condition": "dockerConfigured == false",
      "on_error": "continue"
    },
    {
      "step": 4,
      "layer": "capability",
      "service": "DockerService",
      "action": "autoFix",
      "params": { "source": "docker" },
      "description": "自动修复 Docker 配置问题",
      "auto_execute": true,
      "condition": "dockerConfigured == false",
      "on_error": "continue"
    },
    {
      "step": 5,
      "layer": "core",
      "service": "NotifyService",
      "action": "send",
      "params": {
        "level": "warning",
        "title": "Docker 配置失败",
        "content": "Docker 容器化配置未能完成，请检查项目结构和 Docker 安装"
      },
      "description": "Docker 配置失败通知",
      "auto_execute": true,
      "condition": "dockerConfigured == false",
      "on_error": "continue"
    },
    {
      "step": 6,
      "layer": "capability",
      "service": "MemoryService",
      "action": "remember",
      "params": {
        "type": "docker",
        "data": {
          "dockerfilePath": "{{dockerfilePath}}",
          "composeGenerated": "{{composeGenerated}}",
          "configured": "{{dockerConfigured}}"
        }
      },
      "description": "保存 Docker 配置结果",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 7,
      "layer": "capability",
      "service": "MemoryService",
      "action": "consolidate",
      "params": {},
      "description": "整理去重记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 8,
      "layer": "core",
      "service": "NotifyService",
      "action": "notify",
      "params": { "message": "Docker 容器化配置工作流完成" },
      "description": "通知 Docker 配置完成",
      "auto_execute": true,
      "on_error": "continue"
    }
  ]
}
