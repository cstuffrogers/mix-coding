{
  "scene_id": "log",
  "workflow": "log",
  "name": "日志聚合配置",
  "description": "检测项目日志库（winston/pino/log4js），自动生成结构化日志配置，检测 ELK/Fluentd 并生成采集配置",
  "trigger_keywords": [
    "日志",
    "log",
    "logging",
    "日志配置",
    "ELK",
    "winston",
    "pino"
  ],
  "flow": [
    {
      "step": 1,
      "layer": "core",
      "service": "MemoryService",
      "action": "recall",
      "params": {
        "type": "logging",
        "filters": {
          "type": [
            "logging",
            "log",
            "observability",
            "monitoring"
          ]
        }
      },
      "description": "注入日志相关记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 2,
      "layer": "capability",
      "service": "LoggingService",
      "action": "setupLogging",
      "params": {},
      "description": "检测日志库，生成 logging.config.js",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3,
      "layer": "core",
      "service": "QualityService",
      "action": "checkGate",
      "params": {
        "checks": [
          "logging"
        ]
      },
      "description": "日志配置质量门禁",
      "auto_execute": true,
      "condition": "loggingConfigured == false",
      "on_error": "abort"
    },
    {
      "step": 4,
      "layer": "capability",
      "service": "LoggingService",
      "action": "autoFix",
      "params": {
        "source": "logging"
      },
      "description": "自动修复日志配置问题",
      "auto_execute": true,
      "condition": "loggingConfigured == false",
      "on_error": "continue"
    },
    {
      "step": 5,
      "layer": "core",
      "service": "NotificationService",
      "action": "send",
      "params": {
        "level": "warning",
        "title": "日志配置失败",
        "content": "日志聚合配置未能完成，请检查 package.json 和依赖安装"
      },
      "description": "日志配置失败通知",
      "auto_execute": true,
      "condition": "loggingConfigured == false",
      "on_error": "continue"
    },
    {
      "step": 6,
      "layer": "capability",
      "service": "MemoryService",
      "action": "remember",
      "params": {
        "type": "logging",
        "data": {
          "configPath": "{{loggingConfigPath}}",
          "logFormat": "{{logFormat}}",
          "configured": "{{loggingConfigured}}"
        }
      },
      "description": "保存日志配置结果",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 7,
      "layer": "capability",
      "service": "MemoryService",
      "action": "consolidate",
      "params": {},
      "description": "整理去重记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 7.5,
      "layer": "capability",
      "service": "ECC",
      "action": "ce-compound",
      "params": {
        "type": "log",
        "source": "auto"
      },
      "description": "将log知识沉淀到项目知识库 CLAUDE.md",
      "auto_execute": true,
      "condition": "plugin_ce_available",
      "on_error": "continue"
    },
    {
      "step": 8,
      "layer": "core",
      "service": "NotificationService",
      "action": "notify",
      "params": {
        "message": "日志聚合配置工作流完成"
      },
      "description": "通知日志配置完成",
      "auto_execute": true,
      "on_error": "continue"
    }
  ]
}
