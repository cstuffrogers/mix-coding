{
  "scene_id": "release",
  "workflow": "release",
  "name": "发布部署",
  "description": "端到端发布部署流程：质量门禁 → 版本号 → 构建 → 验证 → Tag → 发布",
  "trigger_keywords": [
    "发布",
    "release",
    "上线",
    "deploy",
    "ship",
    "发版"
  ],
  "flow": [
    {
      "step": 1,
      "layer": "capability",
      "service": "MemoryService",
      "action": "recall",
      "params": {
        "mode": "full",
        "filters": {
          "type": [
            "release",
            "deployment",
            "changelog"
          ]
        }
      },
      "description": "注入历史上下文和相关记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 2,
      "layer": "capability",
      "service": "UpdateService",
      "action": "autoUpdate",
      "params": {
        "mode": "pull",
        "rebase": true
      },
      "description": "拉取最新代码，确保基于最新版本发布",
      "auto_execute": true,
      "on_error": "abort"
    },
    {
      "step": 2.5,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "open-redirect-scan",
      "params": {},
      "description": "开放重定向检测：发布前检查 URL 跳转安全风险",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3,
      "layer": "capability",
      "service": "QualityService",
      "action": "checkGate",
      "params": {
        "checks": [
          "lint",
          "typecheck",
          "test",
          "coverage",
          "security",
          "dependency_audit"
        ],
        "mode": "strict",
        "block_release": true
      },
      "description": "发布前质量门禁：所有检查必须通过，任一失败阻止发布",
      "auto_execute": true,
      "on_error": "abort",
      "criticality": "BLOCK-RELEASE"
    },
    {
      "step": 4,
      "layer": "capability",
      "service": "TestEngine",
      "action": "checkCoverage",
      "params": {
        "threshold": 85,
        "mode": "gate"
      },
      "description": "测试覆盖率门禁：低于85%阈值时阻断发布",
      "auto_execute": true,
      "on_error": "abort"
    },
    {
      "step": 5,
      "layer": "capability",
      "service": "DocsService",
      "action": "generateChangelog",
      "params": {
        "format": "conventional_commits",
        "since": "last_release"
      },
      "description": "从Conventional Commits自动生成CHANGELOG",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 5.5,
      "layer": "capability",
      "service": "QualityTool",
      "action": "dead-link-check",
      "params": {},
      "description": "死链接检测：文档质量检查，不阻断发布 — lychee",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 6,
      "layer": "interactive",
      "service": "SceneSelector",
      "action": "choose",
      "params": {
        "message": "请选择版本升级类型：",
        "options": [
          {
            "label": "major",
            "description": "重大变更，不向后兼容 (X.0.0)"
          },
          {
            "label": "minor",
            "description": "新功能，向后兼容 (0.X.0)"
          },
          {
            "label": "patch",
            "description": "Bug修复，向后兼容 (0.0.X)"
          }
        ]
      },
      "description": "选择语义化版本升级类型",
      "auto_execute": false,
      "on_error": "abort"
    },
    {
      "step": 7,
      "layer": "capability",
      "service": "DocsService",
      "action": "bumpVersion",
      "params": {
        "mode": "semver"
      },
      "description": "根据选择的升级类型自动更新版本号",
      "auto_execute": true,
      "on_error": "abort"
    },
    {
      "step": 8,
      "layer": "capability",
      "service": "BuildService",
      "action": "productionBuild",
      "params": {
        "optimize": true,
        "sourcemap": false
      },
      "description": "执行生产构建（优化、去sourcemap）",
      "auto_execute": true,
      "on_error": "abort",
      "timeout": 600
    },
    {
      "step": 8.5,
      "layer": "capability",
      "service": "SecurityTool",
      "action": "build-leak-check",
      "params": {
        "mode": "ci"
      },
      "description": "构建产物泄露检测：Source Map / .env / 密钥 / .git 目录 — noleak 扫描",
      "auto_execute": true,
      "on_error": "abort",
      "criticality": "BLOCK-RELEASE"
    },
    {
      "step": 8.6,
      "layer": "capability",
      "service": "QualityTool",
      "action": "lighthouse-gate",
      "params": {
        "mode": "ci"
      },
      "description": "性能预算 CI 门禁：LCP/CLS/TBT 断言 + 缓存策略 — Lighthouse CI（阻断发布）",
      "auto_execute": true,
      "on_error": "abort",
      "criticality": "BLOCK-RELEASE"
    },
    {
      "step": 9,
      "layer": "capability",
      "service": "VerifyService",
      "action": "verify",
      "params": {
        "scope": "release",
        "mode": "smoke_test"
      },
      "description": "冒烟测试：验证构建产物可正常运行",
      "auto_execute": true,
      "on_error": "abort",
      "timeout": 300
    },
    {
      "step": 10,
      "layer": "capability",
      "service": "DocsService",
      "action": "createTag",
      "params": {
        "format": "v{version}",
        "annotated": true
      },
      "description": "创建带注释的Git版本标签",
      "auto_execute": true,
      "on_error": "abort"
    },
    {
      "step": 11,
      "layer": "capability",
      "service": "DocsService",
      "action": "deploy",
      "params": {
        "target": "production",
        "strategy": "rolling"
      },
      "description": "执行部署（滚动更新策略）",
      "auto_execute": true,
      "condition": "user_confirmed === true",
      "on_error": "abort",
      "timeout": 900
    },
    {
      "step": 12,
      "layer": "capability",
      "service": "VerifyService",
      "action": "verify",
      "params": {
        "scope": "deployment",
        "mode": "health_check",
        "retry": 3
      },
      "description": "部署后健康检查：确认服务正常响应",
      "auto_execute": true,
      "on_error": "retry",
      "timeout": 180
    },
    {
      "step": 13,
      "layer": "capability",
      "service": "GitService",
      "action": "createRelease",
      "params": {
        "body": "changelog_content",
        "draft": false
      },
      "description": "在GitHub上创建Release并附上CHANGELOG",
      "auto_execute": true,
      "condition": "github_mcp_available",
      "on_error": "continue"
    },
    {
      "step": 13.4,
      "layer": "capability",
      "service": "HuashuService",
      "action": "huashu-release-deck",
      "params": {},
      "description": "Huashu deck-exporter: HTML deck → 可编辑 PPTX (需要 pptxgenjs)",
      "auto_execute": true,
      "condition": "enh_huashu_release_deck",
      "on_error": "continue"
    },
    {
      "step": 13.6,
      "layer": "capability",
      "service": "HuashuService",
      "action": "huashu-release-animation",
      "params": {
        "duration": 5,
        "outputFormat": "mp4"
      },
      "description": "Huashu motion-engine: 生成 release 动画 (MP4/GIF, 需要 sharp+playwright)",
      "auto_execute": true,
      "condition": "enh_huashu_release_animation",
      "on_error": "continue"
    },
    {
      "step": 14,
      "layer": "capability",
      "service": "CostService",
      "action": "report",
      "params": {
        "format": "summary",
        "include": [
          "tokens",
          "api_calls"
        ]
      },
      "description": "发布流程成本报告",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 15,
      "layer": "capability",
      "service": "MemoryService",
      "action": "remember",
      "params": {
        "type": "release",
        "data": {
          "source": "release_workflow"
        }
      },
      "description": "保存发布记录到记忆（版本/变更/部署状态）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 16,
      "layer": "capability",
      "service": "MemoryService",
      "action": "consolidate",
      "params": {},
      "description": "整理跨后端记忆一致性",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 17,
      "layer": "capability",
      "service": "NotificationService",
      "action": "notify",
      "params": {
        "type": "success",
        "message": "🚀 发布完成：版本已上线、健康检查通过"
      },
      "description": "通知用户发布成功",
      "auto_execute": true,
      "on_error": "continue"
    }
  ],
  "status": "active"
}
