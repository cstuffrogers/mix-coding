{
  "scene_id": "plan-ceo-review",
  "workflow": "plan-ceo-review",
  "name": "创始人策略审查",
  "description": "从创始人视角审查功能：找到 10x 版本、砍掉 scope creep、聚焦用户价值",
  "trigger_keywords": [
    "ceo-review",
    "创始人审查",
    "产品策略",
    "founder mode",
    "10x"
  ],
  "flow": [
    {
      "step": 0.5,
      "layer": "capability",
      "service": "MemoryService",
      "action": "recall",
      "params": {
        "mode": "recent",
        "filters": {
          "type": "product_decision"
        }
      },
      "description": "回忆历史产品决策和用户反馈",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 1,
      "layer": "capability",
      "service": "FileReader",
      "action": "readSpec",
      "params": {
        "paths": ["spec.md", "plan.md", "tasks.md", "README.md"]
      },
      "description": "读取功能规格/PRD/任务文档，理解当前方案",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 1.5,
      "layer": "interactive",
      "service": "SceneSelector",
      "action": "confirm",
      "params": {
        "message": "审查目标：当前 feature 分支的功能方案。请确认或指定功能名称。"
      },
      "description": "确认审查目标功能",
      "auto_execute": false,
      "on_error": "abort"
    },
    {
      "step": 2,
      "layer": "interactive",
      "service": "CEOReviewEngine",
      "action": "analyze10x",
      "params": {
        "prompt": "如果只给一周，10x 版本长什么样？不做渐进式修补，从第一性原理重新定义问题。不是好 10%，而是好 10 倍。"
      },
      "description": "10x 分析：从第一性原理重新定义问题，找到突破性方案",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3,
      "layer": "interactive",
      "service": "CEOReviewEngine",
      "action": "detectScopeCreep",
      "params": {
        "prompt": "什么可以砍？识别 scope creep、镀金需求、过度工程化。最简可上线版本（MLP）需要哪些？哪些是一年后也没人会发现的功能？"
      },
      "description": "精简化：识别 scope creep 和可砍功能",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 4,
      "layer": "interactive",
      "service": "CEOReviewEngine",
      "action": "userImpactMatrix",
      "params": {
        "prompt": "用户会注意到并关心吗？这个功能移动什么核心指标？如果不上线用户会流失吗？影响哪些用户画像？"
      },
      "description": "用户价值：评估核心指标影响和用户感知度",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 5,
      "layer": "capability",
      "service": "CEOReviewEngine",
      "action": "categorize",
      "params": {
        "buckets": {
          "must_do": "不做用户会流失，本周内完成",
          "nice_to_have": "锦上添花但不改变决策，可延后",
          "cut": "镀金/过度工程/没人会注意，砍掉或永久推迟"
        }
      },
      "description": "三桶分类：Must-Do / Nice-to-Have / Cut",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 6,
      "layer": "capability",
      "service": "ReportGenerator",
      "action": "generateCEOReport",
      "params": {
        "format": "markdown",
        "output": ".claude/ceo-review-{timestamp}.md"
      },
      "description": "生成结构化审查报告：每条建议含是什么/为什么/用户影响/建议行动",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 7,
      "layer": "capability",
      "service": "MemoryService",
      "action": "remember",
      "params": {
        "type": "product_decision",
        "data": {
          "source": "ceo_review_workflow"
        }
      },
      "description": "保存产品决策到记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 8,
      "layer": "capability",
      "service": "MemoryService",
      "action": "consolidate",
      "params": {},
      "description": "整理跨后端记忆一致性",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 9,
      "layer": "capability",
      "service": "NotificationService",
      "action": "notify",
      "params": {
        "type": "info",
        "message": "CEO 策略审查完成"
      },
      "description": "通知用户审查结果",
      "auto_execute": true,
      "on_error": "continue"
    }
  ],
  "status": "active"
}
