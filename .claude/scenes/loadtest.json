{
  "scene_id": "loadtest",
  "workflow": "loadtest",
  "name": "负载测试",
  "description": "运行 Artillery 负载测试：支持 smoke/load/stress 三种模式，作为 CI/CD 性能门禁",
  "trigger_keywords": [
    "负载测试",
    "load test",
    "压力测试",
    "stress test",
    "性能测试",
    "loadtest",
    "artillery"
  ],
  "flow": [
    {
      "step": 1,
      "layer": "capability",
      "service": "MemoryService",
      "action": "recall",
      "params": {
        "mode": "full",
        "filters": {
          "type": [
            "performance",
            "loadtest",
            "benchmark"
          ]
        }
      },
      "description": "注入历史性能测试记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 2,
      "layer": "capability",
      "service": "BuildService",
      "action": "startDevServer",
      "params": {
        "mode": "background",
        "timeout": 30
      },
      "description": "启动开发服务器（后台模式，等待30秒就绪）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3,
      "layer": "core",
      "service": "TestService",
      "action": "loadTest",
      "params": {
        "mode": "smoke"
      },
      "description": "运行负载测试（默认 smoke 模式）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 4,
      "layer": "core",
      "service": "QualityService",
      "action": "checkGate",
      "params": {
        "checks": [
          "loadtest"
        ]
      },
      "description": "质量门禁：负载测试失败则阻断",
      "auto_execute": true,
      "condition": "loadTestPassed == false",
      "on_error": "abort"
    },
    {
      "step": 5,
      "layer": "capability",
      "service": "NotificationService",
      "action": "send",
      "params": {
        "message": "负载测试失败，请检查性能指标"
      },
      "description": "负载测试失败通知",
      "auto_execute": true,
      "condition": "loadTestPassed == false",
      "on_error": "continue"
    },
    {
      "step": 6,
      "layer": "capability",
      "service": "MemoryService",
      "action": "remember",
      "params": {
        "type": "loadtest",
        "data": {
          "passed": "{{loadTestPassed}}",
          "output": "{{loadTestOutput}}"
        }
      },
      "description": "保存负载测试结果到记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 7,
      "layer": "capability",
      "service": "MemoryService",
      "action": "consolidate",
      "params": {},
      "description": "去重整理记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 7.5,
      "layer": "capability",
      "service": "ECC",
      "action": "ce-compound",
      "params": {
        "type": "loadtest",
        "source": "auto"
      },
      "description": "将loadtest知识沉淀到项目知识库 CLAUDE.md",
      "auto_execute": true,
      "condition": "plugin_ce_available",
      "on_error": "continue"
    },
    {
      "step": 8,
      "layer": "capability",
      "service": "NotificationService",
      "action": "notify",
      "params": {
        "message": "负载测试完成"
      },
      "description": "任务完成通知",
      "auto_execute": true,
      "on_error": "continue"
    }
  ]
}
