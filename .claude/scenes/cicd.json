{
  "scene_id": "cicd",
  "workflow": "cicd",
  "name": "CI/CD 流水线配置",
  "description": "使用 Act + Task 配置本地 CI/CD 流水线，验证 GitHub Actions 工作流，生成 Taskfile.yml 任务运行器",
  "trigger_keywords": ["CI", "CD", "cicd", "ci/cd", "pipeline", "流水线", "workflow", "自动构建", "部署流水线", "GitHub Actions"],
  "flow": [
    {
      "step": 1,
      "layer": "core",
      "service": "MemoryService",
      "action": "recall",
      "params": { "type": "cicd", "filters": { "type": ["ci", "cd", "workflow", "deployment", "pipeline"] } },
      "description": "注入 CI/CD 相关记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 2,
      "layer": "capability",
      "service": "CIService",
      "action": "setupCI",
      "params": {},
      "description": "扫描工作流、验证、生成 Taskfile.yml",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3,
      "layer": "core",
      "service": "QualityService",
      "action": "checkGate",
      "params": { "checks": ["cicd"] },
      "description": "CI/CD 质量门禁",
      "auto_execute": true,
      "condition": "ciConfigured == false",
      "on_error": "continue"
    },
    {
      "step": 4,
      "layer": "capability",
      "service": "CIService",
      "action": "autoFix",
      "params": { "source": "cicd" },
      "description": "自动修复 CI/CD 配置问题",
      "auto_execute": true,
      "condition": "ciConfigured == false",
      "on_error": "continue"
    },
    {
      "step": 5,
      "layer": "core",
      "service": "NotifyService",
      "action": "send",
      "params": {
        "level": "warning",
        "title": "CI/CD 配置失败",
        "content": "未能生成有效的 CI/CD 配置，请检查项目结构"
      },
      "description": "CI/CD 配置失败通知",
      "auto_execute": true,
      "condition": "ciConfigured == false",
      "on_error": "continue"
    },
    {
      "step": 6,
      "layer": "capability",
      "service": "MemoryService",
      "action": "remember",
      "params": {
        "type": "cicd",
        "data": {
          "workflowsFound": "{{workflowsFound}}",
          "workflowsValid": "{{workflowsValid}}",
          "taskfileGenerated": "{{taskfileGenerated}}",
          "actAvailable": "{{actAvailable}}",
          "taskAvailable": "{{taskAvailable}}"
        }
      },
      "description": "保存 CI/CD 配置结果",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 7,
      "layer": "capability",
      "service": "MemoryService",
      "action": "consolidate",
      "params": {},
      "description": "整理去重记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 8,
      "layer": "core",
      "service": "NotifyService",
      "action": "notify",
      "params": { "message": "CI/CD 流水线配置工作流完成" },
      "description": "通知 CI/CD 配置完成",
      "auto_execute": true,
      "on_error": "continue"
    }
  ]
}
