{
  "scene_id": "audit",
  "workflow": "audit",
  "name": "全面项目健康检查",
  "description": "一键全量项目审计：安全扫描 + 代码质量 + 依赖审计 + 性能基线 + 覆盖率 + 质量门禁汇总",
  "trigger_keywords": [
    "审计",
    "健康检查",
    "全面检查",
    "audit",
    "health check",
    "项目体检"
  ],
  "flow": [
    {
      "step": 0.5,
      "layer": "capability",
      "service": "MemoryService",
      "action": "recall",
      "params": {
        "mode": "full",
        "filters": {
          "type": [
            "security",
            "audit",
            "quality"
          ]
        }
      },
      "description": "注入历史审计上下文和安全策略记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 1,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "sec-bug-hunt",
      "params": {
        "scope": "full",
        "min_confidence": 0.8,
        "risk_levels": [
          "LOW",
          "MEDIUM",
          "HIGH",
          "CRITICAL"
        ]
      },
      "description": "全量安全扫描：XSS、SQL注入、CSRF、硬编码密钥、不安全依赖",
      "auto_execute": true,
      "on_error": "continue",
      "timeout": 600
    },
    {
      "step": 2,
      "layer": "capability",
      "service": "ReviewEngine",
      "action": "runReview",
      "params": {
        "mode": "full"
      },
      "description": "五层代码审查：ESLint → react-doctor → Playwright → AI语义 → 聚合",
      "auto_execute": true,
      "on_error": "continue",
      "timeout": 300
    },
    {
      "step": 3,
      "layer": "capability",
      "service": "ReviewEngine",
      "action": "runReview",
      "params": {
        "mode": "security",
        "options": {
          "layers": [
            "static"
          ],
          "rules": [
            "npm-audit"
          ]
        }
      },
      "description": "依赖安全审计：npm audit / pip audit / cargo audit",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.2,
      "layer": "capability",
      "service": "ReviewEngine",
      "action": "runReview",
      "params": {
        "mode": "a11y",
        "options": {
          "standard": "WCAG2.1",
          "level": "AA"
        }
      },
      "description": "WCAG 无障碍扫描：img alt/语义化HTML/aria-label 基础检查",
      "auto_execute": true,
      "condition": "frontend_involved",
      "on_error": "continue"
    },
    {
      "step": 3.3,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "i18n-audit",
      "params": {
        "mode": "check"
      },
      "description": "i18n 国际化审查：硬编码中文字符串、RTL布局适配、i18n配置检测",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.4,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "open-redirect-scan",
      "params": {},
      "description": "开放重定向检测：location.href/window.open 参数注入 + express-sec-audit AST 扫描",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.5,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "security-headers",
      "params": {},
      "description": "安全响应头扫描：CSP/HSTS/X-Frame-Options/X-Content-Type-Options/Referrer-Policy/Permissions-Policy — seraphim-audit（代码配置 + 可选实时 URL 扫描）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.6,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "recheck-cli",
      "params": {},
      "description": "正则 ReDoS 扫描：灾难性回溯检测 — recheck-cli",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.7,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "log-sanitization",
      "params": {},
      "description": "日志脱敏扫描：console.log 中 Token/密码/身份证号/手机号/邮箱泄露检测",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.8,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "cors-check",
      "params": {},
      "description": "CORS 配置检测：Access-Control-Allow-Origin: * / credentials + 通配符 / cors() 无配置",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.9,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "env-var-leak",
      "params": {},
      "description": "前端环境变量泄露检测：Vite import.meta.env 非 VITE_ 前缀 / Next.js process.env 前缀检查",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.10,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "postinstall-check",
      "params": {},
      "description": "恶意 install 脚本检测：node_modules 中 postinstall/preinstall 含 curl/wget/eval/base64/反弹 shell",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.11,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "socket-scan",
      "params": {},
      "description": "Socket.dev 供应链安全扫描：拼写欺诈/抗议软件/遥测包检测（需 SOCKET_API_KEY 环境变量）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.12,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "sensitive-file-check",
      "params": {},
      "description": "敏感文件暴露检查：.env/*.pem/*.key/credentials.json 的 gitignore 规则与 git 追踪状态",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.13,
      "layer": "capability",
      "service": "QualitySkill",
      "action": "tech-debt-scan",
      "params": {},
      "description": "技术债务标记扫描：HACK/FIXME/BUG/XXX/WORKAROUND/TODO 分类统计与严重度分级",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.14,
      "layer": "capability",
      "service": "QualitySkill",
      "action": "lock-file-consistency",
      "params": {},
      "description": "包管理器一致性检查：多锁文件共存检测（package-lock/yarn.lock/pnpm-lock/bun.lockb）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.15,
      "layer": "capability",
      "service": "QualitySkill",
      "action": "gitignore-check",
      "params": {},
      "description": ".gitignore 最佳实践：node_modules/dist/.env/*.log/coverage/.DS_Store/Thumbs.db/build 缺失检查",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.16,
      "layer": "capability",
      "service": "DepsService",
      "action": "deprecated-deps",
      "params": {},
      "description": "废弃/未维护依赖检测：npm outdated 识别 deprecated 包",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 4,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "performanceProfile",
      "params": {
        "mode": "static",
        "target": "all"
      },
      "description": "性能静态分析：识别热点函数、大Bundle、N+1查询模式",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 5,
      "layer": "capability",
      "service": "TestEngine",
      "action": "checkCoverage",
      "params": {
        "threshold": 0,
        "mode": "report"
      },
      "description": "获取当前测试覆盖率（仅报告，不设阈值阻断）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 6,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "codeScan",
      "params": {
        "mode": "full",
        "depth": "deep"
      },
      "description": "代码复杂度扫描：圈复杂度、重复率、文件行数、依赖深度",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 6.5,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "codeMetrics",
      "params": {
        "thresholds": {
          "cyclomatic_complexity": 15,
          "maintainability": 60
        }
      },
      "description": "代码复杂度指标：圈复杂度阈值检查（>15 视为高复杂度）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 6.6,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "state-audit",
      "params": {},
      "description": "状态管理审计：Context API 过度使用、组件耦合度、循环依赖、多库混用检测",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 6.7,
      "layer": "capability",
      "service": "DepsService",
      "action": "checkOutdated",
      "params": {},
      "description": "依赖审计：检测过期 npm 包",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 7,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "knipCheck",
      "params": {
        "mode": "dead_code"
      },
      "description": "死代码检测：未使用文件、未引用导出、多余依赖",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 8,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "gitLeaks",
      "params": {
        "mode": "history"
      },
      "description": "Git 历史密钥扫描：API Key、Token、私钥、JWT 泄露检测",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 8.5,
      "layer": "capability",
      "service": "QualityTool",
      "action": "dead-link-check",
      "params": {},
      "description": "死链接检测：扫描项目 Markdown/HTML 文件中的失效链接 — lychee（全目录扫描）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 8.7,
      "layer": "capability",
      "service": "SecurityTool",
      "action": "build-leak-check",
      "params": {
        "mode": "report"
      },
      "description": "构建产物泄露检测：Source Map / .env / 密钥扫描 — noleak（仅报告）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 8.8,
      "layer": "capability",
      "service": "QualityTool",
      "action": "lighthouse-gate",
      "params": {
        "mode": "report"
      },
      "description": "性能预算门禁：LCP/CLS/TBT 断言 + 缓存策略 + PWA 离线检查 — Lighthouse CI（仅报告）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 9,
      "layer": "capability",
      "service": "QualityService",
      "action": "checkGate",
      "params": {
        "checks": [
          "security",
          "lint",
          "dependencies",
          "performance",
          "coverage",
          "complexity",
          "dead_code",
          "git_leaks",
          "dead_links",
          "build_leaks",
          "open_redirect",
          "security_headers",
          "recheck",
          "state_audit",
          "lighthouse",
          "a11y",
          "i18n",
          "log_sanitization",
          "cors_check",
          "env_var_leak",
          "postinstall",
          "socket_scan",
          "sensitive_file",
          "tech_debt",
          "lock_file",
          "gitignore_check",
          "deprecated_deps"
        ],
        "mode": "report_only"
      },
      "description": "汇总所有检查结果为统一健康报告（仅报告，不阻断）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 10,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "generateReport",
      "params": {
        "format": "markdown",
        "destination": "docs/audit-report.md",
        "sections": [
          "security",
          "quality",
          "dependencies",
          "performance",
          "coverage",
          "complexity",
          "dead_code",
          "git_leaks",
          "dead_links",
          "build_leaks",
          "open_redirect",
          "security_headers",
          "recheck",
          "state_audit",
          "lighthouse",
          "a11y",
          "i18n",
          "log_sanitization",
          "cors_check",
          "env_var_leak",
          "postinstall",
          "socket_scan",
          "sensitive_file",
          "tech_debt",
          "lock_file",
          "gitignore_check",
          "deprecated_deps"
        ]
      },
      "description": "生成全面审计报告：包含各项得分、风险等级、改进建议",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 10.5,
      "layer": "capability",
      "service": "HuashuService",
      "action": "huashu-infographic",
      "params": {
        "title": "Project Health Audit"
      },
      "description": "Huashu infographic: 将审计指标渲染为单页 HTML 信息图（editorial-brutalism）",
      "auto_execute": true,
      "condition": "enh_huashu_infographic",
      "on_error": "continue"
    },
    {
      "step": 11,
      "layer": "interactive",
      "service": "SceneSelector",
      "action": "report",
      "params": {
        "message": "📊 项目健康检查报告已生成\n\n报告位置：docs/audit-report.md\n\n是否根据发现的问题执行自动修复？",
        "validation": {
          "type": "boolean",
          "default": false
        }
      },
      "description": "展示审计摘要，询问是否自动修复",
      "auto_execute": false,
      "on_error": "abort"
    },
    {
      "step": 12,
      "layer": "capability",
      "service": "CodeEngine",
      "action": "autoFix",
      "params": {
        "mode": "all",
        "include": [
          "security",
          "lint",
          "dependencies"
        ]
      },
      "description": "根据审计结果执行自动修复（安全+规范+依赖）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 13,
      "layer": "capability",
      "service": "CostService",
      "action": "report",
      "params": {
        "format": "summary",
        "include": [
          "tokens",
          "api_calls"
        ]
      },
      "description": "审计流程成本报告",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 14,
      "layer": "capability",
      "service": "MemoryService",
      "action": "remember",
      "params": {
        "type": "audit",
        "data": {
          "source": "audit_workflow"
        }
      },
      "description": "保存审计结果到多后端记忆（安全发现/质量指标/性能热点）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 14.5,
      "layer": "capability",
      "service": "MemoryService",
      "action": "consolidate",
      "params": {},
      "description": "整理跨后端记忆一致性，去重过期条目",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 15,
      "layer": "capability",
      "service": "NotificationService",
      "action": "notify",
      "params": {
        "type": "info",
        "message": "项目健康检查完成：报告已保存至 docs/audit-report.md"
      },
      "description": "通知用户审计完成",
      "auto_execute": true,
      "on_error": "continue"
    }
  ],
  "status": "active"
}
