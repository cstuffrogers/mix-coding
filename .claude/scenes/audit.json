{
  "scene_id": "audit",
  "workflow": "audit",
  "name": "全面项目健康检查",
  "description": "一键全量项目审计：安全扫描 + 代码质量 + 依赖审计 + 性能基线 + 覆盖率 + 质量门禁汇总",
  "trigger_keywords": [
    "审计",
    "健康检查",
    "全面检查",
    "audit",
    "health check",
    "项目体检"
  ],
  "flow": [
    {
      "step": 0.3,
      "layer": "skill",
      "service": "Skill",
      "action": "invokeSkill",
      "params": {
        "skill": "review-checklist"
      },
      "description": "Pre-flight: 加载 23 项审查清单，建立审计基准框架",
      "auto_execute": true,
      "condition": "conversation_mode",
      "on_error": "continue"
    },
    {
      "step": 0.5,
      "layer": "capability",
      "service": "MemoryService",
      "action": "recall",
      "params": {
        "mode": "full",
        "filters": {
          "type": [
            "security",
            "audit",
            "quality"
          ]
        }
      },
      "description": "注入历史审计上下文和安全策略记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 1,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "sec-bug-hunt",
      "params": {
        "scope": "full",
        "min_confidence": 0.8,
        "risk_levels": [
          "LOW",
          "MEDIUM",
          "HIGH",
          "CRITICAL"
        ]
      },
      "description": "全量安全扫描：XSS、SQL注入、CSRF、硬编码密钥、不安全依赖",
      "auto_execute": true,
      "on_error": "continue",
      "timeout": 600
    },
    {
      "step": 2,
      "layer": "capability",
      "service": "ReviewEngine",
      "action": "runReview",
      "params": {
        "mode": "full"
      },
      "description": "五层代码审查：ESLint → react-doctor → Playwright → AI语义 → 聚合",
      "auto_execute": true,
      "on_error": "continue",
      "timeout": 300
    },
    {
      "step": 3,
      "layer": "capability",
      "service": "ReviewEngine",
      "action": "runReview",
      "params": {
        "mode": "security",
        "options": {
          "layers": [
            "static"
          ],
          "rules": [
            "npm-audit"
          ]
        }
      },
      "description": "依赖安全审计：npm audit / pip audit / cargo audit",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.02,
      "layer": "capability",
      "service": "ReviewEngine",
      "action": "runReview",
      "params": {
        "mode": "a11y",
        "options": {
          "standard": "WCAG2.1",
          "level": "AA"
        }
      },
      "description": "WCAG 无障碍扫描：img alt/语义化HTML/aria-label 基础检查",
      "auto_execute": true,
      "condition": "frontend_involved",
      "on_error": "continue"
    },
    {
      "step": 3.03,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "i18n-audit",
      "params": {
        "mode": "check"
      },
      "description": "i18n 国际化审查：硬编码中文字符串、RTL布局适配、i18n配置检测",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.04,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "open-redirect-scan",
      "params": {},
      "description": "开放重定向检测：location.href/window.open 参数注入",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.05,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "security-headers",
      "params": {},
      "description": "安全响应头扫描：CSP/HSTS/X-Frame-Options/X-Content-Type-Options/Referrer-Policy/Permissions-Policy — seraphim-audit（代码配置 + 可选实时 URL 扫描）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.06,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "recheck-cli",
      "params": {},
      "description": "正则 ReDoS 扫描：灾难性回溯检测 — recheck-cli",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.07,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "log-sanitization",
      "params": {},
      "description": "日志脱敏扫描：console.log 中 Token/密码/身份证号/手机号/邮箱泄露检测",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.08,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "cors-check",
      "params": {},
      "description": "CORS 配置检测：Access-Control-Allow-Origin: * / credentials + 通配符 / cors() 无配置",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.09,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "env-var-leak",
      "params": {},
      "description": "前端环境变量泄露检测：Vite import.meta.env 非 VITE_ 前缀 / Next.js process.env 前缀检查",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.12,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "sensitive-file-check",
      "params": {},
      "description": "敏感文件暴露检查：.env/*.pem/*.key/credentials.json 的 gitignore 规则与 git 追踪状态",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.16,
      "layer": "capability",
      "service": "DepsService",
      "action": "deprecated-deps",
      "params": {},
      "description": "废弃/未维护依赖检测：npm outdated 识别 deprecated 包",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.17,
      "layer": "capability",
      "service": "MetaCheckService",
      "action": "verify-handlers",
      "params": {},
      "description": "Handler 功能性验证：扫描 ACTION_REGISTRY + CE dispatch + handler 文件，检测空转桩（MCP/MP/CE/伪桩）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.18,
      "layer": "capability",
      "service": "SkillSecurityService",
      "action": "skillspector-scan",
      "params": {
        "targets": [
          ".claude/skills/",
          ".claude/commands/"
        ],
        "format": "json"
      },
      "description": "AI 技能安全扫描：扫描 .claude/skills/ .claude/commands/ 中的提示注入、数据外泄、权限提升、恶意代理等 64 种漏洞模式（NVIDIA SkillSpector）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.19,
      "layer": "capability",
      "service": "AISlopService",
      "action": "aislop-scan",
      "params": {
        "mode": "scan"
      },
      "description": "AI 代码气味扫描（aislop）：50+ 规则 — 叙事注释、吞异常、死代码、as any 滥用、重复 helper、过多抽象层级",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.195,
      "layer": "capability",
      "service": "CodeQualityService",
      "action": "knip-check",
      "params": {},
      "description": "Knip 死代码检测：未使用文件 / 未使用导出 / 未使用依赖 / 未解析导入",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.21,
      "layer": "capability",
      "service": "ArchitectureService",
      "action": "depcruise-architecture",
      "params": {},
      "description": "依赖架构验证（dependency-cruiser）：循环依赖检测、孤儿模块识别、架构分层合规、调用图生成",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.22,
      "layer": "capability",
      "service": "CIService",
      "action": "actionlint",
      "params": {},
      "description": "GitHub Actions 工作流语法检查（actionlint）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.23,
      "layer": "capability",
      "service": "SecuritySkill",
      "action": "zizmor",
      "params": {},
      "description": "GitHub Actions 安全审计（zizmor）：权限过度/脚本注入/敏感数据暴露",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.24,
      "layer": "capability",
      "service": "CodeQualityService",
      "action": "jscpd",
      "params": {},
      "description": "代码重复检测（jscpd）：AST 级 copy-paste 检测，min-tokens 50，重复率 > 5% 告警",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.25,
      "layer": "capability",
      "service": "BundleSizeService",
      "action": "size_limit",
      "params": {},
      "description": "包体积预算检查（size-limit）：JS bundle 体积是否超出 .size-limit.json 配置的预算",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.26,
      "layer": "capability",
      "service": "MutationTestService",
      "action": "stryker",
      "params": {},
      "description": "Stryker 变异测试：运行变异测试框架，计算变异体杀死率（≥80% 通过），检测测试套件质量",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.27,
      "layer": "capability",
      "service": "SecurityTool",
      "action": "spectral",
      "params": {},
      "description": "Spectral API lint：扫描 OpenAPI/Swagger 规范文件，检测 API 设计违规（error 级别阻断）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 3.28,
      "layer": "capability",
      "service": "CodeQualityService",
      "action": "markdownlint",
      "params": {},
      "description": "markdownlint 检查：扫描项目 Markdown 文件，检测格式问题（MD 规则）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 4,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "performanceProfile",
      "params": {
        "mode": "static",
        "target": "all"
      },
      "description": "性能静态分析：识别热点函数、大Bundle、N+1查询模式",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 5,
      "layer": "capability",
      "service": "TestEngine",
      "action": "checkCoverage",
      "params": {
        "threshold": 0,
        "mode": "report"
      },
      "description": "获取当前测试覆盖率（仅报告，不设阈值阻断）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 6,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "codeScan",
      "params": {
        "mode": "full",
        "depth": "deep"
      },
      "description": "代码复杂度扫描：圈复杂度、重复率、文件行数、依赖深度",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 6.5,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "codeMetrics",
      "params": {
        "thresholds": {
          "cyclomatic_complexity": 15,
          "maintainability": 60
        }
      },
      "description": "代码复杂度指标：圈复杂度阈值检查（>15 视为高复杂度）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 6.6,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "state-audit",
      "params": {},
      "description": "状态管理审计：Context API 过度使用、组件耦合度、循环依赖、多库混用检测",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 6.7,
      "layer": "capability",
      "service": "DepsService",
      "action": "checkOutdated",
      "params": {},
      "description": "依赖审计：检测过期 npm 包",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 8,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "gitLeaks",
      "params": {
        "mode": "history"
      },
      "description": "Git 历史密钥扫描：API Key、Token、私钥、JWT 泄露检测",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 8.5,
      "layer": "capability",
      "service": "QualityTool",
      "action": "dead-link-check",
      "params": {},
      "description": "死链接检测：扫描项目 Markdown/HTML 文件中的失效链接 — lychee（全目录扫描）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 8.7,
      "layer": "capability",
      "service": "SecurityTool",
      "action": "build-leak-check",
      "params": {
        "mode": "report"
      },
      "description": "构建产物泄露检测：Source Map / .env / 密钥扫描 — noleak（仅报告）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 8.8,
      "layer": "capability",
      "service": "QualityTool",
      "action": "lighthouse-gate",
      "params": {
        "mode": "report"
      },
      "description": "性能预算门禁：LCP/CLS/TBT 断言 + 缓存策略 + PWA 离线检查 — Lighthouse CI（仅报告）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 9,
      "layer": "capability",
      "service": "QualityService",
      "action": "checkGate",
      "params": {
        "checks": [
          "security",
          "lint",
          "dependencies",
          "performance",
          "coverage",
          "complexity",
          "dead_code",
          "git_leaks",
          "dead_links",
          "build_leaks",
          "open_redirect",
          "security_headers",
          "recheck",
          "state_audit",
          "lighthouse",
          "a11y",
          "i18n",
          "log_sanitization",
          "cors_check",
          "env_var_leak",
          "sensitive_file",
          "deprecated_deps",
          "skillspector",
          "aislop",
          "depcruise",
          "knip",
          "actionlint",
          "zizmor",
          "jscpd",
          "size_limit",
          "stryker",
          "spectral",
          "markdownlint"
        ],
        "mode": "report_only"
      },
      "description": "汇总所有检查结果为统一健康报告（仅报告，不阻断）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 10,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "generateReport",
      "params": {
        "format": "markdown",
        "destination": "docs/audit-report.md",
        "sections": [
          "security",
          "quality",
          "dependencies",
          "performance",
          "coverage",
          "complexity",
          "dead_code",
          "git_leaks",
          "dead_links",
          "build_leaks",
          "open_redirect",
          "security_headers",
          "recheck",
          "state_audit",
          "lighthouse",
          "a11y",
          "i18n",
          "log_sanitization",
          "cors_check",
          "env_var_leak",
          "sensitive_file",
          "deprecated_deps",
          "skillspector",
          "aislop",
          "depcruise",
          "knip",
          "stryker",
          "spectral",
          "markdownlint"
        ]
      },
      "description": "生成全面审计报告：包含各项得分、风险等级、改进建议",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 10.5,
      "layer": "capability",
      "service": "HuashuService",
      "action": "huashu-infographic",
      "params": {
        "title": "Project Health Audit"
      },
      "description": "Huashu infographic: 将审计指标渲染为单页 HTML 信息图（editorial-brutalism）",
      "auto_execute": true,
      "condition": "enh_huashu_infographic",
      "on_error": "continue"
    },
    {
      "step": 10.7,
      "layer": "capability",
      "service": "CodeAnalyzer",
      "action": "detectAntiPatterns",
      "params": {
        "mode": "deep",
        "include": [
          "god_module",
          "fat_handler",
          "circular_deps",
          "layer_violation"
        ]
      },
      "description": "架构深度审计：God Module检测 + 分层合规 + 依赖分析 + 复杂度热点图",
      "auto_execute": true,
      "condition": "enh_architecture_deep_audit",
      "on_error": "continue"
    },
    {
      "step": 11,
      "layer": "interactive",
      "service": "SceneSelector",
      "action": "report",
      "params": {
        "message": "📊 项目健康检查报告已生成\n\n报告位置：docs/audit-report.md\n\n是否根据发现的问题执行自动修复？",
        "validation": {
          "type": "boolean",
          "default": false
        }
      },
      "description": "展示审计摘要，询问是否自动修复",
      "auto_execute": false,
      "on_error": "abort"
    },
    {
      "step": 12,
      "layer": "capability",
      "service": "CodeEngine",
      "action": "autoFix",
      "params": {
        "mode": "all",
        "include": [
          "security",
          "lint",
          "dependencies"
        ]
      },
      "description": "根据审计结果执行自动修复（安全+规范+依赖）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 13,
      "layer": "capability",
      "service": "CostService",
      "action": "report",
      "params": {
        "format": "summary",
        "include": [
          "tokens",
          "api_calls"
        ]
      },
      "description": "审计流程成本报告",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 13.5,
      "layer": "capability",
      "service": "ECC",
      "action": "ce-compound",
      "params": {
        "type": "audit",
        "source": "auto"
      },
      "description": "将审计发现沉淀到项目知识库 CLAUDE.md",
      "auto_execute": true,
      "condition": "plugin_ce_available",
      "on_error": "continue"
    },
    {
      "step": 14,
      "layer": "capability",
      "service": "MemoryService",
      "action": "remember",
      "params": {
        "type": "audit",
        "data": {
          "source": "audit_workflow"
        }
      },
      "description": "保存审计结果到多后端记忆（安全发现/质量指标/性能热点）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 14.5,
      "layer": "capability",
      "service": "MemoryService",
      "action": "consolidate",
      "params": {},
      "description": "整理跨后端记忆一致性，去重过期条目",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 15,
      "layer": "capability",
      "service": "NotificationService",
      "action": "notify",
      "params": {
        "type": "info",
        "message": "项目健康检查完成：报告已保存至 docs/audit-report.md"
      },
      "description": "通知用户审计完成",
      "auto_execute": true,
      "on_error": "continue"
    }
  ],
  "status": "active"
}