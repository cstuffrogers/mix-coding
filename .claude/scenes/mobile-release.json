{
  "scene_id": "mobile-release",
  "workflow": "mobile-release",
  "name": "移动端发布流程",
  "description": "端到端移动端发布：证书检查→质量门禁→版本号→CHANGELOG→fastlane构建签名→TestFlight/Google Play→OTA热更新→Sentry崩溃监控",
  "trigger_keywords": [
    "发布App",
    "App上线",
    "移动端发布",
    "TestFlight",
    "应用商店发布",
    "mobile release",
    "App deploy",
    "帮我发布"
  ],
  "flow": [
    {
      "step": 0.5,
      "layer": "capability",
      "service": "MemoryService",
      "action": "recall",
      "params": {
        "mode": "full",
        "filters": {
          "type": ["mobile-release", "deployment", "release"]
        }
      },
      "description": "注入历史发布记录和配置记忆",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 1,
      "layer": "capability",
      "service": "MobileService",
      "action": "detectProject",
      "params": {},
      "description": "识别平台→确定发布渠道（iOS→TestFlight/App Store, Android→Play Internal/Production, 小程序→体验版/审核）",
      "auto_execute": true,
      "on_error": "abort"
    },
    {
      "step": 2,
      "layer": "capability",
      "service": "MobileService",
      "action": "releaseChecks",
      "params": {},
      "description": "发布前环境检查：证书/Profile有效性(iOS)、签名密钥(Android)、隐私标签、测试账号",
      "auto_execute": true,
      "on_error": "abort"
    },
    {
      "step": 3,
      "layer": "capability",
      "service": "QualityService",
      "action": "checkGate",
      "params": {
        "checks": ["security_scan", "performance_baseline", "tests_pass", "store_compliance"],
        "mode": "strict",
        "block_release": true
      },
      "description": "发布前质量门禁：安全扫描通过（无CRITICAL/HIGH）+ 性能基线达标 + 测试通过 + 商店合规",
      "auto_execute": true,
      "on_error": "abort",
      "criticality": "BLOCK-RELEASE"
    },
    {
      "step": 4,
      "layer": "interactive",
      "service": "SceneSelector",
      "action": "confirm",
      "params": {
        "message": "📱 准备发布到以下渠道：\n\niOS: TestFlight 内部测试\nAndroid: Google Play Internal Testing\n\n请选择版本升级类型：",
        "options": [
          { "label": "patch", "description": "Bug修复 (1.0.X)" },
          { "label": "minor", "description": "新功能 (1.X.0)" },
          { "label": "major", "description": "重大更新 (X.0.0)" }
        ]
      },
      "description": "确认发布渠道和版本升级类型，仅此一步需要人工确认",
      "auto_execute": false,
      "on_error": "abort"
    },
    {
      "step": 5,
      "layer": "capability",
      "service": "MobileService",
      "action": "mobileBumpVersion",
      "params": {
        "mode": "semver",
        "source_step": 4
      },
      "produces": "new_version",
      "description": "自动更新版本号（从 step 4 获取 bump_type → 更新 package.json/build.gradle/Info.plist/pubspec.yaml）→ 输出版本号供后续步骤使用",
      "auto_execute": true,
      "on_error": "abort"
    },
    {
      "step": 6,
      "layer": "capability",
      "service": "MobileService",
      "action": "mobileGenerateChangelog",
      "params": {
        "format": "conventional_commits"
      },
      "consumes": "new_version",
      "produces": "changelog_content",
      "description": "从 Conventional Commits 自动生成 CHANGELOG（基于 new_version，构建前生成，随 release 一起发布）→ 输出 changelog_content 供 GitHub Release 使用",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 7,
      "layer": "capability",
      "service": "MobileService",
      "action": "grayReleaseConfig",
      "params": {},
      "consumes": "new_version",
      "description": "灰度发布配置（基于 new_version）：分阶段 rollout 比例 + 强制更新策略 + 版本兼容矩阵（构建前设定，纳入构建参数）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 8,
      "layer": "capability",
      "service": "MobileService",
      "action": "iosRelease",
      "params": {
        "lane": "beta"
      },
      "description": "iOS: fastlane gym archive → upload to TestFlight（条件：iOS项目）",
      "auto_execute": true,
      "condition": "ios_platform",
      "on_error": "abort",
      "timeout": 1200
    },
    {
      "step": 9,
      "layer": "capability",
      "service": "MobileService",
      "action": "androidRelease",
      "params": {
        "track": "internal"
      },
      "description": "Android: fastlane gradle build → AAB签名 → Play Internal Testing（条件：Android项目）",
      "auto_execute": true,
      "condition": "android_platform",
      "on_error": "abort",
      "timeout": 1200
    },
    {
      "step": 10,
      "layer": "capability",
      "service": "ShorebirdMCP",
      "action": "shorebirdPatch",
      "params": {},
      "description": "Shorebird OTA 热更新资源包发布（可选，条件：Flutter/RN + Shorebird已配置）",
      "auto_execute": true,
      "condition": "flutter_or_rn && shorebird_available",
      "on_error": "continue"
    },
    {
      "step": 11,
      "layer": "capability",
      "service": "GitHubMCP",
      "action": "createRelease",
      "params": {
        "body_ref": "changelog_content",
        "tag_ref": "new_version",
        "draft": false,
        "prerelease": true
      },
      "consumes": ["changelog_content", "new_version"],
      "description": "GitHub Release + CHANGELOG（body_ref/tag_ref 分别引用 step 6 和 step 5 产出）",
      "auto_execute": true,
      "condition": "github_mcp_available",
      "on_error": "continue"
    },
    {
      "step": 12,
      "layer": "capability",
      "service": "SentryMCP",
      "action": "sentryCheckRelease",
      "params": {},
      "description": "Sentry 发布后崩溃率监控基线（新版本 crash-free rate 对比）",
      "auto_execute": true,
      "condition": "sentry_mcp_available",
      "on_error": "continue"
    },
    {
      "step": 13,
      "layer": "capability",
      "service": "ECC",
      "action": "ce-compound",
      "params": {
        "type": "mobile-release",
        "source": "auto"
      },
      "description": "发布流程知识沉淀",
      "auto_execute": true,
      "condition": "plugin_ce_available",
      "on_error": "continue"
    },
    {
      "step": 14,
      "layer": "capability",
      "service": "CostService",
      "action": "report",
      "params": {
        "format": "summary",
        "include": ["tokens", "api_calls"]
      },
      "description": "发布流程成本报告",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 15,
      "layer": "capability",
      "service": "MemoryService",
      "action": "remember",
      "params": {
        "type": "mobile-release",
        "data": {
          "source": "mobile-release_workflow"
        }
      },
      "description": "保存发布记录到记忆（版本号/渠道/构建号/发布状态）",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 16,
      "layer": "capability",
      "service": "MemoryService",
      "action": "consolidate",
      "params": {},
      "description": "整理跨后端记忆一致性",
      "auto_execute": true,
      "on_error": "continue"
    },
    {
      "step": 17,
      "layer": "capability",
      "service": "NotificationService",
      "action": "notify",
      "params": {
        "type": "success",
        "message": "发布完成 🚀 iOS TestFlight + Android Play Internal Testing 已提交，审核通过后将自动上架"
      },
      "description": "通知发布结果",
      "auto_execute": true,
      "on_error": "continue"
    }
  ],
  "status": "active"
}
