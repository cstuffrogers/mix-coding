{
  "scene_id": "deps",
  "workflow": "deps",
  "name": "依赖更新",
  "description": "安全依赖更新流程：检查过期 → 逐项更新 → 测试验证 → 检查breaking changes → 更新lockfile",
  "trigger_keywords": [
    "更新依赖",
    "升级依赖",
    "deps",
    "dependency update",
    "过期的包",
    "npm update"
  ],
  "flow": [
    {
      "step": 0.3,
      "layer": "skill",
      "service": "SkillRunner",
      "action": "invokeSkill",
      "params": {
        "skill": "review-checklist"
      },
      "description": "Pre-flight: 加载 23 项审查清单（正确性/类型安全/安全/性能/测试/可维护性），建立结构化审查基准",
      "condition": "conversation_mode"
    },
    {
      "step": 1,
      "layer": "capability",
      "service": "MemoryService",
      "action": "recall",
      "params": {
        "mode": "full",
        "filters": {
          "type": [
            "deps",
            "dependency",
            "security"
          ]
        }
      },
      "description": "注入历史上下文和相关记忆"
    },
    {
      "step": 2,
      "layer": "capability",
      "service": "UpdateService",
      "action": "autoUpdate",
      "params": {
        "mode": "pull",
        "rebase": true
      },
      "description": "拉取最新代码后再更新依赖"
    },
    {
      "step": 3,
      "layer": "capability",
      "service": "BuildService",
      "action": "checkOutdated",
      "params": {
        "ecosystem": "auto",
        "include_dev": true
      },
      "description": "扫描所有过期依赖（自动检测 npm/pip/cargo/go mod）",
      "on_error": "abort"
    },
    {
      "step": 3.5,
      "layer": "capability",
      "service": "DepsService",
      "action": "deprecated-deps",
      "params": {
        "ecosystem": "auto",
        "includeTransitive": false
      },
      "description": "废弃/未维护依赖检测：npm outdated 识别 deprecated 包，标记已停止维护的依赖"
    },
    {
      "step": 4,
      "layer": "capability",
      "service": "ReviewEngine",
      "action": "runReview",
      "params": {
        "mode": "security",
        "options": {
          "layers": [
            "static"
          ],
          "rules": [
            "npm-audit"
          ]
        }
      },
      "description": "安全审计当前依赖：识别已知漏洞"
    },
    {
      "step": 5,
      "layer": "interactive",
      "service": "SceneSelector",
      "action": "choose",
      "params": {
        "message": "检测到以下过期依赖，请选择更新策略：",
        "options": [
          {
            "label": "安全更新",
            "description": "仅更新有安全漏洞的依赖（最安全）"
          },
          {
            "label": "补丁更新",
            "description": "更新所有patch版本（向后兼容）"
          },
          {
            "label": "小版本更新",
            "description": "更新minor+patch版本（可能有新特性）"
          },
          {
            "label": "全量更新",
            "description": "更新所有依赖到最新版本（风险最高）"
          }
        ]
      },
      "description": "选择依赖更新策略",
      "auto_execute": false,
      "on_error": "abort"
    },
    {
      "step": 6,
      "layer": "capability",
      "service": "TestEngine",
      "action": "runSuite",
      "params": {
        "mode": "unit"
      },
      "description": "更新前运行测试建立基线",
      "on_error": "abort"
    },
    {
      "step": 7,
      "layer": "capability",
      "service": "BuildService",
      "action": "updateDeps",
      "params": {
        "mode": "incremental",
        "auto_fix": true
      },
      "description": "逐项更新依赖，每次更新后运行测试",
      "timeout": 600
    },
    {
      "step": 8,
      "layer": "capability",
      "service": "TestEngine",
      "action": "runSuite",
      "params": {
        "mode": "unit",
        "regression": true
      },
      "description": "全部更新完成后运行全量回归测试",
      "on_error": "abort"
    },
    {
      "step": 9,
      "layer": "capability",
      "service": "BuildService",
      "action": "checkBreakingChanges",
      "params": {
        "compare_to": "lockfile_baseline"
      },
      "description": "检查更新是否引入breaking changes（API变更检测）"
    },
    {
      "step": 10,
      "layer": "capability",
      "service": "VerifyService",
      "action": "verify",
      "params": {
        "scope": "dependency_update",
        "mode": "smoke_test"
      },
      "description": "快速冒烟测试确保应用正常运行",
      "on_error": "abort",
      "timeout": 180
    },
    {
      "step": 11,
      "layer": "capability",
      "service": "ProjectService",
      "action": "commitPush",
      "params": {
        "message": "chore: 更新依赖",
        "push_remote": true
      },
      "description": "提交更新的lockfile和package.json",
      "condition": "testPassed === true"
    },
    {
      "step": 12,
      "layer": "capability",
      "service": "MemoryService",
      "action": "remember",
      "params": {
        "type": "deps",
        "data": {
          "source": "deps_workflow"
        }
      },
      "description": "保存依赖更新记录到记忆"
    },
    {
      "step": 13,
      "layer": "capability",
      "service": "MemoryService",
      "action": "consolidate",
      "params": {},
      "description": "整理跨后端记忆一致性"
    },
    {
      "layer": "capability",
      "service": "ECC",
      "action": "ce-compound",
      "params": {
        "type": "deps",
        "source": "auto"
      },
      "description": "将deps知识沉淀到项目知识库 CLAUDE.md",
      "condition": "plugin_ce_available",
      "step": 13.5
    },
    {
      "step": 14,
      "layer": "capability",
      "service": "NotificationService",
      "action": "notify",
      "params": {
        "type": "success",
        "message": "依赖更新完成：测试通过、代码已提交"
      },
      "description": "通知用户依赖更新结果"
    }
  ],
  "status": "active"
}
