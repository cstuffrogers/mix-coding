{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Feature List",
  "description": "Machine-readable feature tracking for Harness Engineering. Defines scope boundaries the agent cannot ignore.",
  "type": "object",
  "required": ["project", "version", "features"],
  "properties": {
    "project": {
      "type": "string",
      "description": "Project name"
    },
    "version": {
      "type": "string",
      "description": "Current project version (semver)"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "wip_limit": {
      "type": "integer",
      "default": 1,
      "description": "Maximum number of in-progress features. MUST be 1 for Harness compliance."
    },
    "features": {
      "type": "array",
      "description": "All features in the project",
      "items": {
        "type": "object",
        "required": ["id", "name", "status"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique feature identifier (e.g., F001, auth-login, etc.)"
          },
          "name": {
            "type": "string",
            "description": "Human-readable feature name"
          },
          "description": {
            "type": "string",
            "description": "Brief description of what this feature does"
          },
          "status": {
            "type": "string",
            "enum": ["todo", "in_progress", "review", "done", "blocked"],
            "description": "Current feature status"
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "default": "medium",
            "description": "Feature priority"
          },
          "definition_of_done": {
            "type": "array",
            "description": "Explicit checklist for when this feature is considered complete",
            "items": {
              "type": "string"
            }
          },
          "dependencies": {
            "type": "array",
            "description": "Feature IDs that must be completed before this one",
            "items": {
              "type": "string"
            }
          },
          "assigned_scene": {
            "type": "string",
            "enum": ["/new-project", "/feature", "/bugfix", "/refactor", "/design", "/review", "/hunt", "/analyze", "/loop", "/simplify", "/optimize", "/polish"],
            "description": "Which scene command should be used to implement this feature"
          },
          "estimated_effort": {
            "type": "string",
            "enum": ["small", "medium", "large", "epic"],
            "description": "Rough effort estimate"
          },
          "notes": {
            "type": "string",
            "description": "Additional notes, blockers, or context"
          }
        }
      }
    },
    "milestones": {
      "type": "array",
      "description": "Optional: Group features into milestones",
      "items": {
        "type": "object",
        "required": ["id", "name", "status"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["planned", "in_progress", "completed"]
          },
          "feature_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "target_date": {
            "type": "string",
            "format": "date"
          }
        }
      }
    }
  }
}
