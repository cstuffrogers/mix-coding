{
  "_comment": "LIGHTWEIGHT mode: only 4 MCP servers active. For full 14 servers, restore from .mcp.json.full: cp .mcp.json.full .mcp.json",
  "_modes": {
    "current": "light",
    "active_servers": ["mempalace", "context7", "github", "sentry"]
  },
  "mcpServers": {
    "mempalace": {
      "command": "C:\\Users\\Administrator\\.local\\bin\\mempalace-mcp.exe",
      "args": [],
      "description": "MemPalace 本地优先 AI 记忆 (v3.3.5, 启动快)"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "description": "Context7 文档查询 (高频使用)"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "description": "GitHub 仓库操作 - PR/Issue/Repo"
    },
    "sentry": {
      "command": "npx",
      "args": ["-y", "sentry-mcp"],
      "env": {
        "SENTRY_AUTH_TOKEN": "${SENTRY_AUTH_TOKEN}"
      },
      "description": "Sentry 错误监控"
    }
  }
}
