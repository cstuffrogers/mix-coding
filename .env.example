# 12-factor-agents 配置分离示例
# 复制为 .env 并填入实际值

# Anthropic API Key (用于 Claude Code Headless 和 archon AI 节点)
ANTHROPIC_API_KEY=sk-ant-api03-...

# GitHub 集成
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# Tavily 搜索 API
TAVILY_API_KEY=tvly-...

# Sentry 错误监控
SENTRY_AUTH_TOKEN=...

# Context7 文档查询
# 由 /context7 命令自动配置

# Supabase 数据库
SUPABASE_ACCESS_TOKEN=...

# Stripe 支付
STRIPE_SECRET_KEY=sk_test_...

# Resend 邮件服务
RESEND_API_KEY=re_...

# 通知渠道配置
NOTIFY_CHANNEL=dingtalk  # 或 feishu / email
NOTIFY_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=...

# NEXO Brain 模型配置（如使用）
# NEXO_MODEL=gpt-4.1

# Supermemory 云端记忆（可选，不设则仅用本地 6 后端）
# 获取 API Key: https://console.supermemory.ai
# SUPERMEMORY_API_KEY=sm_...
